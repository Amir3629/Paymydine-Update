"use client"

import { useEffect, useLayoutEffect, useState } from "react"

type Rect = {
  left: number
  top: number
  width: number
  height: number
}

const carIcon = (
  <svg
    aria-hidden="true"
    viewBox="0 0 24 24"
    width="30"
    height="30"
    fill="none"
    stroke="currentColor"
    strokeWidth="1.9"
    strokeLinecap="round"
    strokeLinejoin="round"
  >
    <path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2" />
    <circle cx="7" cy="17" r="2" />
    <path d="M9 17h6" />
    <circle cx="17" cy="17" r="2" />
  </svg>
)

export default function OrganicValetInline() {
  // PMD_V0_INLINE_VALET_FINAL_20260609
  const [buttonRect, setButtonRect] = useState<Rect | null>(null)
  const [isOpen, setIsOpen] = useState(false)
  const [status, setStatus] = useState<"idle" | "submitting" | "success">("idle")
  const [formData, setFormData] = useState({
    name: "",
    plate: "",
    car: "",
  })

  useLayoutEffect(() => {
    let savedButton: HTMLButtonElement | null = null

    const findOldTopLeftButton = () => {
      if (savedButton && document.body.contains(savedButton)) return savedButton

      const buttons = Array.from(document.querySelectorAll("button")) as HTMLButtonElement[]
      const viewportWidth = window.innerWidth || 1200

      const candidates = buttons
        .map((button) => {
          const rect = button.getBoundingClientRect()
          const text = (button.textContent || "").trim().toLowerCase()
          const html = button.innerHTML.toLowerCase()
          const className = String(button.className || "").toLowerCase()

          let score = 0

          if (text === "en" || text === "de" || text === "fa") return { button, score: -9999 }
          if (button.dataset.pmdV0InlineValetOldButton === "1") return { button, score: 9999 }

          if (rect.width < 42 || rect.height < 42) return { button, score: -9999 }
          if (rect.width > 130 || rect.height > 130) return { button, score: -9999 }
          if (rect.top < 15 || rect.top > 170) return { button, score: -9999 }
          if (rect.left < 0 || rect.left > viewportWidth * 0.66) return { button, score: -9999 }

          if (html.includes("svg")) score += 30
          if (className.includes("rounded")) score += 20
          if (rect.width >= 55 && rect.width <= 110) score += 30
          if (rect.height >= 55 && rect.height <= 110) score += 30
          if (rect.top >= 35 && rect.top <= 130) score += 20

          // In this v0 layout the real header/menu button is inside the centered page, not at far left.
          if (rect.left > 140) score += 45
          if (rect.left < 120) score -= 80

          return { button, score }
        })
        .filter((item) => item.score > -1000)
        .sort((a, b) => b.score - a.score)

      savedButton = candidates[0]?.button || null
      return savedButton
    }

    const hideOldDropdown = () => {
      Array.from(document.querySelectorAll("div, nav, section, ul")).forEach((el) => {
        const node = el as HTMLElement
        const text = (node.textContent || "").replace(/\s+/g, " ").trim()
        const rect = node.getBoundingClientRect()

        const looksLikeMenuDropdown =
          text.includes("Menu") &&
          text.includes("Valet") &&
          rect.width >= 120 &&
          rect.width <= 560 &&
          rect.height >= 70 &&
          rect.height <= 380 &&
          rect.top >= 40 &&
          rect.top <= 330

        if (!looksLikeMenuDropdown) return

        node.style.setProperty("display", "none", "important")
        node.style.setProperty("visibility", "hidden", "important")
        node.style.setProperty("pointer-events", "none", "important")
        node.setAttribute("aria-hidden", "true")
      })
    }

    const measureAndHide = () => {
      const oldButton = findOldTopLeftButton()

      if (!oldButton) {
        hideOldDropdown()
        return
      }

      const rect = oldButton.getBoundingClientRect()

      oldButton.dataset.pmdV0InlineValetOldButton = "1"
      oldButton.setAttribute("aria-hidden", "true")
      oldButton.setAttribute("tabIndex", "-1")
      oldButton.style.setProperty("visibility", "hidden", "important")
      oldButton.style.setProperty("pointer-events", "none", "important")
      oldButton.style.setProperty("opacity", "0", "important")

      setButtonRect({
        left: rect.left,
        top: rect.top,
        width: rect.width,
        height: rect.height,
      })

      hideOldDropdown()
    }

    measureAndHide()

    const timers = [0, 60, 160, 320, 700, 1300, 2200].map((ms) =>
      window.setTimeout(measureAndHide, ms)
    )

    window.addEventListener("resize", measureAndHide)
    window.addEventListener("scroll", hideOldDropdown, true)

    return () => {
      timers.forEach((timer) => window.clearTimeout(timer))
      window.removeEventListener("resize", measureAndHide)
      window.removeEventListener("scroll", hideOldDropdown, true)
    }
  }, [])

  useEffect(() => {
    if (!isOpen) return

    const onKey = (event: KeyboardEvent) => {
      if (event.key === "Escape") setIsOpen(false)
    }

    window.addEventListener("keydown", onKey)
    return () => window.removeEventListener("keydown", onKey)
  }, [isOpen])

  const openCard = () => {
    setStatus("idle")
    setIsOpen(true)
  }

  const closeCard = () => {
    setIsOpen(false)
    setStatus("idle")
  }

  const submit = async (event: React.FormEvent<HTMLFormElement>) => {
    event.preventDefault()

    if (!formData.name.trim() || !formData.plate.trim()) return

    setStatus("submitting")

    try {
      window.localStorage.setItem(
        "pmd-v0-organic-valet-request",
        JSON.stringify({
          ...formData,
          createdAt: new Date().toISOString(),
          source: "v0-inline-valet",
        })
      )
    } catch (error) {}

    await new Promise((resolve) => window.setTimeout(resolve, 650))
    setStatus("success")
  }

  const fallbackLeft =
    "max(1rem, calc((100vw - min(760px, 100vw)) / 2 + 1.25rem))"

  return (
    <>
      <button
        type="button"
        data-pmd-v0-inline-valet-button="1"
        aria-label="Valet Parking Service"
        title="Valet Parking Service"
        onClick={(event) => {
          event.preventDefault()
          event.stopPropagation()
          openCard()
        }}
        style={{
          position: "fixed",
          left: buttonRect ? `${buttonRect.left}px` : fallbackLeft,
          top: buttonRect ? `${buttonRect.top}px` : "3.5rem",
          width: buttonRect ? `${buttonRect.width}px` : "5.25rem",
          height: buttonRect ? `${buttonRect.height}px` : "5.25rem",
          zIndex: 999999,
          display: "inline-flex",
          alignItems: "center",
          justifyContent: "center",
          borderRadius: "9999px",
          border: "1px solid #ded2ba",
          background: "#fffaf0",
          color: "#747d55",
          WebkitTextFillColor: "#747d55",
          boxShadow:
            "0 18px 42px -22px rgba(60,53,41,.82), inset 0 1px 0 rgba(255,255,255,.72)",
          cursor: "pointer",
        }}
      >
        {carIcon}
      </button>

      {isOpen ? (
        <div
          data-pmd-v0-inline-valet-modal="1"
          role="dialog"
          aria-modal="true"
          aria-label="Valet Parking Service"
          onMouseDown={(event) => {
            if (event.target === event.currentTarget) closeCard()
          }}
          style={{
            position: "fixed",
            inset: 0,
            zIndex: 1000000,
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            padding: "2rem 1rem",
            background: "rgba(35,31,26,.46)",
            backdropFilter: "blur(8px) saturate(.95)",
            WebkitBackdropFilter: "blur(8px) saturate(.95)",
          }}
        >
          <div
            style={{
              position: "relative",
              width: "min(100%, 27rem)",
              overflow: "hidden",
              borderRadius: "2rem",
              border: "1px solid #ded2ba",
              padding: "1.5rem",
              color: "#343529",
              boxShadow:
                "0 24px 70px -20px rgba(60,53,41,.52), inset 0 1px 0 rgba(255,255,255,.72)",
            }}
          >
            <div
              aria-hidden="true"
              style={{
                position: "absolute",
                inset: 0,
                zIndex: 0,
                backgroundColor: "#fffaf0",
                backgroundImage:
                  "linear-gradient(180deg, rgba(255,255,255,.42), rgba(255,255,255,0)), radial-gradient(circle at 1px 1px, rgba(116,125,85,.085) 1px, transparent 0)",
                backgroundSize: "100% 100%, 16px 16px",
                backgroundRepeat: "no-repeat, repeat",
              }}
            />

            <div style={{ position: "relative", zIndex: 1 }}>
              <div style={{ display: "flex", alignItems: "center", gap: ".85rem", marginBottom: "1.25rem" }}>
                <span
                  style={{
                    display: "inline-flex",
                    width: "3rem",
                    height: "3rem",
                    alignItems: "center",
                    justifyContent: "center",
                    borderRadius: "9999px",
                    border: "1px solid #ded2ba",
                    background: "#fffaf0",
                    color: "#747d55",
                  }}
                >
                  {carIcon}
                </span>
                <div>
                  <h2 style={{ margin: 0, fontSize: "1.25rem", fontWeight: 700, color: "#343529" }}>
                    Valet Parking Service
                  </h2>
                  <p style={{ margin: ".2rem 0 0", fontSize: ".78rem", color: "#746f61" }}>
                    Request valet without leaving the menu.
                  </p>
                </div>
              </div>

              {status === "success" ? (
                <div style={{ textAlign: "center" }}>
                  <div
                    style={{
                      margin: "0 auto 1rem",
                      display: "flex",
                      width: "3.5rem",
                      height: "3.5rem",
                      alignItems: "center",
                      justifyContent: "center",
                      borderRadius: "9999px",
                      background: "#747d55",
                      color: "#fffaf0",
                    }}
                  >
                    ✓
                  </div>
                  <h3 style={{ margin: 0, fontSize: "1.1rem", color: "#343529" }}>
                    Valet request received
                  </h3>
                  <p style={{ margin: ".75rem 0 1.25rem", fontSize: ".9rem", color: "#746f61" }}>
                    Please have your ticket ready when retrieving your vehicle.
                  </p>
                  <button
                    type="button"
                    onClick={closeCard}
                    style={{
                      minHeight: "2.8rem",
                      width: "100%",
                      borderRadius: "9999px",
                      border: "1px solid #747d55",
                      background: "#747d55",
                      color: "#fffaf0",
                      fontWeight: 700,
                      cursor: "pointer",
                    }}
                  >
                    Close
                  </button>
                </div>
              ) : (
                <form onSubmit={submit} style={{ display: "grid", gap: "1rem" }}>
                  <label style={{ display: "grid", gap: ".4rem", fontWeight: 700, color: "#343529" }}>
                    Enter your name *
                    <input
                      value={formData.name}
                      onChange={(event) => setFormData((prev) => ({ ...prev, name: event.target.value }))}
                      required
                      placeholder="Enter your name"
                      style={{
                        height: "2.85rem",
                        borderRadius: "1rem",
                        border: "1px solid #ded2ba",
                        background: "#fffaf0",
                        padding: "0 .9rem",
                        color: "#343529",
                        outline: "none",
                      }}
                    />
                  </label>

                  <label style={{ display: "grid", gap: ".4rem", fontWeight: 700, color: "#343529" }}>
                    License Plate *
                    <input
                      value={formData.plate}
                      onChange={(event) => setFormData((prev) => ({ ...prev, plate: event.target.value }))}
                      required
                      placeholder="Enter license plate"
                      style={{
                        height: "2.85rem",
                        borderRadius: "1rem",
                        border: "1px solid #ded2ba",
                        background: "#fffaf0",
                        padding: "0 .9rem",
                        color: "#343529",
                        outline: "none",
                      }}
                    />
                  </label>

                  <label style={{ display: "grid", gap: ".4rem", fontWeight: 700, color: "#343529" }}>
                    Car Details <span style={{ color: "#746f61", fontWeight: 400 }}>(optional)</span>
                    <input
                      value={formData.car}
                      onChange={(event) => setFormData((prev) => ({ ...prev, car: event.target.value }))}
                      placeholder="Make, model, and color"
                      style={{
                        height: "2.85rem",
                        borderRadius: "1rem",
                        border: "1px solid #ded2ba",
                        background: "#fffaf0",
                        padding: "0 .9rem",
                        color: "#343529",
                        outline: "none",
                      }}
                    />
                  </label>

                  <button
                    type="submit"
                    disabled={status === "submitting"}
                    style={{
                      minHeight: "2.9rem",
                      borderRadius: "9999px",
                      border: "1px solid #747d55",
                      background: "#747d55",
                      color: "#fffaf0",
                      fontWeight: 800,
                      cursor: "pointer",
                      opacity: status === "submitting" ? .75 : 1,
                    }}
                  >
                    {status === "submitting" ? "Submitting..." : "Request Valet Service"}
                  </button>

                  <div
                    style={{
                      borderRadius: "1rem",
                      border: "1px solid #ded2ba",
                      background: "#f6efe2",
                      padding: "1rem",
                      color: "#746f61",
                      fontSize: ".9rem",
                      lineHeight: 1.45,
                    }}
                  >
                    <p style={{ margin: "0 0 .4rem" }}>
                      Our valet service is available during restaurant hours.
                    </p>
                    <p style={{ margin: 0 }}>
                      Please have your ticket ready when retrieving your vehicle.
                    </p>
                  </div>
                </form>
              )}
            </div>
          </div>
        </div>
      ) : null}
    </>
  )
}
