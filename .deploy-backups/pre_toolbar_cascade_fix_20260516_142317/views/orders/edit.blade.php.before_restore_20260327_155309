<style>
/* hide old temporary POS box completely */
#pmd-pos-tax-note-safe {
    display: none !important;
}

/* move header card a bit lower so top labels are fully visible */
.order-info-header {
    margin-top: 22px !important;
    padding-top: 14px !important;
}

/* improve visibility of header labels */
.order-info-header .order-info-label {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    margin-bottom: 8px !important;
    line-height: 1.2 !important;
}

/* POS import meta inside invoice card */
.pmd-pos-inline-meta {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid #e5e9f2;
    font-size: 13px;
    line-height: 1.6;
    color: #526484;
}
.pmd-pos-inline-meta .pmd-pos-inline-source {
    font-weight: 600;
    color: #364a63;
}
</style>
<style>

/* hide ugly imported note */
.note-card, .order-notes, .card:has(.note-icon-btn) {
    /* fallback safe */
}

/* better note button alignment */
.note-button-container {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
}

/* injected POS meta inside invoice */
.pmd-pos-final-meta {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid #e5e9f2;
    font-size: 13px;
    color: #526484;
    line-height: 1.6;
}

.pmd-pos-final-meta strong {
    color: #364a63;
    font-weight: 600;
}

</style>


<script>
(function () {
    function getOrderIdFromUrl() {
        try {
            var m = window.location.pathname.match(/\/admin\/orders\/edit\/(\d+)/);
            return m ? m[1] : null;
        } catch (e) {
            return null;
        }
    }

    function formatMoney(v) {
        var n = Number(v);
        if (isNaN(n)) return null;
        return '€' + n.toFixed(2);
    }

    function removeFloatingNote() {
        var old = document.getElementById('pmd-pos-tax-note-safe');
        if (old) old.remove();
    }

    function mountInvoiceMeta(meta) {
        removeFloatingNote();

        var invoiceCard = document.querySelector('.card .invoice, .invoice-card, .invoice-panel');
        var invoiceBox = document.querySelector('.card-body .invoice-buttons-container');

        var rightCard = null;
        var headings = document.querySelectorAll('.card-body .card-title, .card-body h1, .card-body h2, .card-body h3, .card-body h4, .card-body h5');
        headings.forEach(function(h){
            if ((h.textContent || '').trim().toLowerCase() === 'invoice') {
                rightCard = h.closest('.card');
            }
        });

        if (!rightCard) {
            var customerTextNodes = Array.from(document.querySelectorAll('*')).filter(function(el){
                return (el.textContent || '').trim() === 'Customer';
            });
            if (customerTextNodes.length) {
                var maybeCard = customerTextNodes[0].closest('.card');
                if (maybeCard && maybeCard.previousElementSibling) {
                    rightCard = maybeCard.previousElementSibling;
                }
            }
        }

        if (!rightCard) {
            rightCard = Array.from(document.querySelectorAll('.card')).find(function(card){
                return /Invoice/.test(card.innerText || '');
            }) || null;
        }

        if (!rightCard) return;

        var oldMeta = rightCard.querySelector('.pmd-pos-inline-meta');
        if (oldMeta) oldMeta.remove();

        var metaBox = document.createElement('div');
        metaBox.className = 'pmd-pos-inline-meta';

        var parts = [];
        if (meta && meta.source) parts.push('Source: ' + meta.source);
        if (meta && meta.invoice_number) parts.push('Invoice: ' + meta.invoice_number);
        if (meta && meta.gross !== null && meta.gross !== undefined) parts.push('Gross: ' + formatMoney(meta.gross));
        if (meta && meta.net !== null && meta.net !== undefined) parts.push('Net: ' + formatMoney(meta.net));

        metaBox.innerHTML = '<span class="pmd-pos-inline-source">' + parts.join(' | ') + '</span>';

        var body = rightCard.querySelector('.card-body');
        if (body) {
            body.appendChild(metaBox);
        } else {
            rightCard.appendChild(metaBox);
        }
    }

    function applyHeaderFix(meta) {
        var tableValue = document.querySelector('.order-info-item.table-number .order-info-value');
        if (!tableValue) return;

        var name = null;
        if (meta) {
            if (meta.mapped_local_table_name) name = meta.mapped_local_table_name;
            else if (meta.table_name) name = meta.table_name;
        }

        if (!name) {
            var bodyText = document.body.innerText || '';
            var m1 = bodyText.match(/mapped_local_table_name=([^|\n]+)/i);
            if (m1 && m1[1]) name = m1[1].trim();
            if (!name) {
                var m2 = bodyText.match(/table_name=([^|\n]+)/i);
                if (m2 && m2[1]) name = m2[1].trim();
            }
        }

        if (name && name !== 'Table' && name !== 'Table ') {
            tableValue.textContent = name;
        }
    }

    function triggerBillPatch(meta) {
        window.__PMD_POS_META = meta || null;

        var tries = 0;
        function ping() {
            tries++;
            if (typeof window.PMD_POS_META_APPLY === 'function') {
                window.PMD_POS_META_APPLY(meta || null);
            }
            if (tries < 8) setTimeout(ping, 400);
        }
        ping();
    }

    function run() {
        var orderId = getOrderIdFromUrl();
        if (!orderId) return;

        fetch('/order_pos_tax_lookup_ajax.php?order_id=' + encodeURIComponent(orderId), {
            credentials: 'same-origin',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function (r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function (data) {
            if (!data || !data.success || !data.meta || !data.meta.is_pos_import) return;
            removeFloatingNote();
            mountInvoiceMeta(data.meta);
            applyHeaderFix(data.meta);
            triggerBillPatch(data.meta);
        })
        .catch(function (err) {
            console.log('PMD order edit POS patch skipped:', err.message);
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        setTimeout(run, 250);
        setTimeout(run, 900);
        setTimeout(run, 1800);
    });
})();

<script>
(function(){

function extractMetaFromComment(text){
    if(!text) return null;

    const get = (key) => {
        const m = text.match(new RegExp(key + '=([^|]+)'));
        return m ? m[1].trim() : null;
    };

    return {
        source: text.includes('ready2order') ? 'ready2order' : null,
        invoice: get('invoice_number'),
        gross: get('gross'),
        net: get('net'),
        vat: get('vat')
    };
}

function mountFinalInvoiceMeta(){
    // find invoice card
    let invoiceCard = [...document.querySelectorAll('.card')].find(c =>
        (c.innerText || '').includes('Invoice')
    );
    if(!invoiceCard) return;

    let body = invoiceCard.querySelector('.card-body');
    if(!body) return;

    // remove old
    let old = body.querySelector('.pmd-pos-final-meta');
    if(old) old.remove();

    // get comment text
    let noteTextEl = document.querySelector('.order-notes, .card-body');
    let raw = document.body.innerText;

    let meta = extractMetaFromComment(raw);
    if(!meta || !meta.invoice) return;

    let box = document.createElement('div');
    box.className = 'pmd-pos-final-meta';

    box.innerHTML = `
        <div><strong>Source:</strong> ${meta.source}</div>
        <div><strong>POS Invoice:</strong> ${meta.invoice}</div>
        <div><strong>Gross:</strong> €${parseFloat(meta.gross).toFixed(2)}</div>
        <div><strong>Net:</strong> €${parseFloat(meta.net).toFixed(2)}</div>
    `;

    body.appendChild(box);

    // FIX USER AGENT
    let uaRow = [...body.querySelectorAll('*')].find(e =>
        (e.innerText || '').includes('API Client')
    );
    if(uaRow){
        uaRow.innerText = 'ready2order (POS)';
    }
}

setTimeout(mountFinalInvoiceMeta, 500);
setTimeout(mountFinalInvoiceMeta, 1500);

})();
</script>

</script>
