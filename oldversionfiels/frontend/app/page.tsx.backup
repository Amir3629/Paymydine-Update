"use client"

import { useEffect, useState } from "react"
import { categories, menuData, type MenuItem } from "@/lib/data"
import { useLanguageStore } from "@/store/language-store"
import { useCmsStore } from "@/store/cms-store"
import { useCartStore } from "@/store/cart-store"
import { Logo } from "@/components/logo"
import { BottomActions } from "@/components/bottom-actions"
import { CartSheet } from "../components/cart-sheet"
import { CategoryNav } from "@/components/category-nav"
import { MenuItemModal } from "@/components/menu-item-modal"
import { Button } from "@/components/ui/button"
import { Plus } from "lucide-react"
import Image from "next/image"
import { motion } from "framer-motion"
import clsx from "clsx"
import React from "react"
import { FoodItemToolbar } from "@/components/food-item-toolbar"

// Menu Item Card with Button Animation and Quantity Badge
function MenuItemCard({ item, onSelect, onFirstAdd }: { item: MenuItem; onSelect: (item: MenuItem) => void; onFirstAdd?: () => void }) {
  const addToCart = useCartStore((state) => state.addToCart)
  const { items } = useCartStore()
  const { t } = useLanguageStore()
  const [isAnimating, setIsAnimating] = useState(false)

  // Get current quantity for this item
  const currentItem = items.find(cartItem => cartItem.item.id === item.id)
  const quantity = currentItem?.quantity || 0

  const handleAdd = (e: React.MouseEvent) => {
    e.stopPropagation()
    setIsAnimating(true)
    addToCart(item)
    if (onFirstAdd && quantity === 0) onFirstAdd()
    setTimeout(() => setIsAnimating(false), 600)
  }

  const itemName = item.nameKey ? t(item.nameKey as any) : item.name
  const itemDescription = item.descriptionKey ? t(item.descriptionKey as any) : item.description

  return (
    <div
      className="flex items-center space-x-4 group cursor-pointer"
      onClick={() => onSelect(item)}
    >
      <div className="relative w-28 h-28 md:w-36 md:h-36 flex-shrink-0">
        <Image
          src={item.image || "/placeholder.svg"}
          alt={itemName}
          fill
          className="object-contain transition-transform duration-700 ease-in-out group-hover:scale-110"
        />
      </div>
      <div className="flex-grow">
        <h3 className="font-serif text-lg font-bold text-paydine-elegant-gray">{itemName}</h3>
        <p className="text-sm text-gray-500 mt-1 line-clamp-2">{itemDescription}</p>
        <div className="flex justify-between items-center mt-2">
          <p className="text-lg font-semibold text-paydine-champagne">${(item.price || 0).toFixed(2)}</p>
          <div className="relative">
            <Button
              size="icon"
              variant="ghost"
              className={clsx(
                "rounded-full bg-paydine-rose-beige/50 hover:bg-paydine-champagne text-paydine-elegant-gray w-12 h-12 transition-all duration-300 hover:scale-105 font-bold text-lg",
                isAnimating && "animate-pulse scale-110 bg-paydine-champagne shadow-lg btn-animate btn-glow"
              )}
              onClick={handleAdd}
            >
              {quantity > 0 ? (
                <span className="text-lg font-bold">{quantity}</span>
              ) : (
                <Plus className="h-5 w-5" />
              )}
              <span className="sr-only">Add to cart</span>
            </Button>
            {quantity > 0 && (
              <span className="absolute -top-2 -right-2 text-paydine-champagne text-base font-bold">
                +
              </span>
            )}
          </div>
        </div>
      </div>
    </div>
  )
}

export default function HomePage() {
  const [selectedCategory, setSelectedCategory] = useState<MenuItem["category"]>("Mains")
  const [selectedItem, setSelectedItem] = useState<MenuItem | null>(null)
  const [isWaiterConfirmOpen, setWaiterConfirmOpen] = useState(false)
  const [isNoteModalOpen, setNoteModalOpen] = useState(false)
  const [note, setNote] = useState("")
  const { t } = useLanguageStore()
  const { items, toggleCart } = useCartStore()

  const totalItems = items.reduce((acc, item) => acc + item.quantity, 0)
  const totalPrice = items.reduce((acc, item) => acc + item.item.price * item.quantity, 0)

  const handleWaiterClick = () => setWaiterConfirmOpen(true)
  const handleNoteClick = () => setNoteModalOpen(true)

  const filteredItems = menuData.filter((item) => item.category === selectedCategory)

  return (
    <div className="min-h-screen bg-white">
      <header className="sticky top-0 z-30 bg-white border-b border-gray-100">
        <div className="container mx-auto px-4 py-4">
          <Logo />
        </div>
        <CategoryNav
          categories={categories}
          selectedCategory={selectedCategory}
          onSelectCategory={setSelectedCategory}
        />
      </header>

      <main className="container mx-auto py-8">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
          {filteredItems.map((item) => (
            <MenuItemCard
              key={item.id}
              item={item}
              onSelect={setSelectedItem}
            />
          ))}
        </div>
      </main>

      <MenuItemModal
        item={selectedItem}
        onClose={() => setSelectedItem(null)}
      />

      <CartSheet />

      <div className="fixed bottom-0 left-0 right-0 pb-4 z-40">
        <BottomActions />
      </div>
    </div>
  )
}