# Required
PMD_BASE_URL=https://mimoza.paymydine.com
PMD_USERNAME=admin
PMD_PASSWORD=change-me

# Target page
PMD_FINAL_PATH=/admin/dashboardwaiternewfinal

# Runtime controls
PMD_WORKERS=1
PMD_HEADLESS=1
PMD_SLOW_MO=0
PMD_EXPECT_TIMEOUT_MS=12000
PMD_ACTION_TIMEOUT_MS=15000
PMD_NAVIGATION_TIMEOUT_MS=45000
PMD_MAX_LAYOUT_SHIFT=0.10
PMD_MAX_LONG_TASKS=12

# Optional safe validation inputs
PMD_TEST_COUPON=
PMD_ALLOW_COUPON_VALIDATION=0

# Real mutations are OFF by default.
# Use only on dedicated test tables and a test tenant.
PMD_ALLOW_MUTATIONS=0
PMD_TEST_TABLES=10,17
PMD_MUTATION_MODE=hold
PMD_TEST_PRODUCT=
PMD_TEST_NOTE=PLAYWRIGHT QA
PMD_CLEANUP_VOID=0
PMD_ALLOW_PAYMENT_MUTATIONS=0

# Optional comma-separated patterns ignored only for console/network assertions.
PMD_IGNORE_CONSOLE_PATTERNS=favicon.ico,ResizeObserver loop
PMD_IGNORE_NETWORK_PATTERNS=favicon.ico
