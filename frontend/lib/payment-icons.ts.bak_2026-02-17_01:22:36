const KNOWN = new Set([
  "cod",
  "paypal",
  "stripe",
  "authorizenetaim",
  "google_pay",
  "apple_pay",
  "square",
]);

/**
 * Prefer PNG if available (e.g., real logos you placed), otherwise use SVG.
 * Toggle entries to true if the corresponding PNG exists in /public/images/payments.
 * (paypal uses .svg - file was misnamed as .png but content is SVG)
 */
const PNG_ONLY = new Set<string>([
  "google_pay",
  "apple_pay",
  "cod",
  "stripe",
  "authorizenetaim",
  "square",
]);

// Absolute origin for static assets, e.g. http://127.0.0.1:3000
const ORIGIN = (process.env.NEXT_PUBLIC_STATIC_ORIGIN || "").replace(/\/+$/, "");

function makePath(rel: string) {
  return ORIGIN ? `${ORIGIN}${rel}` : rel;
}

/** Normalize API code to our asset key (lowercase; known variants). Production API may return "PayPal" etc. */
const CODE_ALIASES: Record<string, string> = {
  paypal_express: "paypal",
  // add other backend variants if needed
};

export function iconForPayment(code: string): string {
  const raw = code ?? "";
  const trimmed = raw.trim();
  const key = CODE_ALIASES[trimmed.toLowerCase()] ?? trimmed.toLowerCase();

  // Temporary debugging: full dump in dev; in prod log only when falling back to default
  const known = KNOWN.has(key);
  if (typeof window !== "undefined") {
    if (process.env.NODE_ENV === "development") {
      const path = known
        ? makePath(`/images/payments/${key}.${PNG_ONLY.has(key) ? "png" : "svg"}`)
        : makePath("/images/payments/default.svg");
      console.debug("[iconForPayment]", {
        raw: JSON.stringify(raw),
        keyAfterTrim: JSON.stringify(key),
        KNOWN_has_key: known,
        finalPath: path,
        NEXT_PUBLIC_STATIC_ORIGIN: process.env.NEXT_PUBLIC_STATIC_ORIGIN ?? "(unset)",
      });
    } else if (!known) {
      console.warn("[iconForPayment] Unknown code, using default.svg", { raw: JSON.stringify(raw), key });
    }
  }

  if (!known) return makePath("/images/payments/default.svg");
  const ext = PNG_ONLY.has(key) ? "png" : "svg";
  return makePath(`/images/payments/${key}.${ext}`);
}