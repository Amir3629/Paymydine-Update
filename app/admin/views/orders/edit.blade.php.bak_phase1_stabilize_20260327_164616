<script>
(function () {
    function getOrderId() {
        var m = window.location.pathname.match(/\/admin\/orders\/edit\/(\d+)/);
        return m ? m[1] : null;
    }

    function euro(v) {
        var n = Number(v);
        if (isNaN(n)) return null;
        return '€' + n.toFixed(2);
    }

    function findInvoiceCard() {
        var cards = Array.from(document.querySelectorAll('.card'));
        for (var i = 0; i < cards.length; i++) {
            var t = (cards[i].innerText || '').trim();
            if (t.indexOf('Invoice') !== -1 && t.indexOf('Date Added') !== -1) {
                return cards[i];
            }
        }
        return null;
    }

    function mountInvoiceMeta(meta) {
        if (!meta || !meta.is_pos_import) return;
        var card = findInvoiceCard();
        if (!card) return;

        var body = card.querySelector('.card-body') || card;
        var old = body.querySelector('.pmd-pos-inline-meta');
        if (old) old.remove();

        var box = document.createElement('div');
        box.className = 'pmd-pos-inline-meta';
        box.innerHTML =
            '<div><strong>Source:</strong> ' + (meta.source || 'ready2order') + '</div>' +
            '<div><strong>POS Invoice:</strong> ' + (meta.invoice_number || '-') + '</div>' +
            '<div><strong>Gross:</strong> ' + (euro(meta.gross) || '-') + '</div>' +
            '<div><strong>Net:</strong> ' + (euro(meta.net) || '-') + '</div>';

        body.appendChild(box);

        // Replace API Client text visually
        var nodes = Array.from(body.querySelectorAll('*'));
        nodes.forEach(function (el) {
            if ((el.textContent || '').trim() === 'API Client') {
                el.textContent = 'ready2order (POS)';
            }
        });
    }

    function hideRawImportedNotes() {
        var cards = Array.from(document.querySelectorAll('.card'));
        cards.forEach(function(card) {
            var txt = card.innerText || '';
            if (txt.indexOf('Notes') !== -1 && txt.indexOf('Imported from ready2order') !== -1) {
                card.classList.add('pmd-hide-r2o-raw-note');
            }
        });
    }

    function run() {
        var orderId = getOrderId();
        if (!orderId) return;

        fetch('/order_pos_tax_lookup_ajax.php?order_id=' + encodeURIComponent(orderId), {
            credentials: 'same-origin',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
            if (!data || !data.success || !data.meta) return;
            mountInvoiceMeta(data.meta);
            hideRawImportedNotes();
        })
        .catch(function () {});
    }

    document.addEventListener('DOMContentLoaded', function () {
        setTimeout(run, 250);
        setTimeout(run, 900);
        setTimeout(run, 1800);
    });
})();
</script>
