<script>
(function () {
    function markReady() {
        try {
            document.documentElement.classList.remove('pmd-pos-pending');
            document.documentElement.classList.add('pmd-pos-ready');
        } catch (e) {}
    }

    function waitForPosPatch() {
        var tries = 0;
        var timer = setInterval(function () {
            tries++;

            var uaOk = false;
            var billOk = false;
            var tableOk = false;

            var bodyText = document.body ? (document.body.innerText || '') : '';

            uaOk = bodyText.indexOf('ready2order (POS)') !== -1;

            var tableEl = document.querySelector('.order-info-item.table-number .order-info-value');
            if (tableEl) {
                var txt = (tableEl.textContent || '').trim();
                tableOk = txt !== '' && txt.toLowerCase() !== 'table';
            }

            var totalText = bodyText;
            billOk = totalText.indexOf('VAT included') !== -1 && totalText.indexOf('€22.03') !== -1
                || totalText.indexOf('€138.00') !== -1
                || totalText.indexOf('€9.00') !== -1
                || totalText.indexOf('€12.00') !== -1;

            if ((uaOk || tableOk || billOk) && tries >= 2) {
                clearInterval(timer);
                markReady();
            }

            if (tries > 20) {
                clearInterval(timer);
                markReady(); // fail-safe
            }
        }, 150);
    }

    document.addEventListener('DOMContentLoaded', function () {
        waitForPosPatch();
    });

    window.addEventListener('load', function () {
        setTimeout(waitForPosPatch, 100);
    });
})();
</script>
