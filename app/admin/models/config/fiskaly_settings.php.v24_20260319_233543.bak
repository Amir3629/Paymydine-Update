            'fiskaly_api_key' => [
                'label' => 'API Key',
                'type' => 'text',
                'span' => 'left',
                'comment' => 'Paste the API Key from your Fiskaly account.',
            ],

            'fiskaly_api_secret' => [
                'label' => 'API Secret',
                'type' => 'text',
                'span' => 'right',
                'comment' => 'Paste the API Secret from your Fiskaly account.',
            ],

            'fiskaly_organization_id' => [
                'label' => 'Organization ID',
                'type' => 'text',
                'span' => 'left',
                'comment' => 'Your Fiskaly organization ID.',
            ],

            'fiskaly_tss_id' => [
                'label' => 'TSS ID',
                'type' => 'text',
                'span' => 'right',
                'comment' => 'Usually created automatically by the system if empty.',
            ],

            'fiskaly_client_id' => [
                'label' => 'Client ID',
                'type' => 'text',
                'span' => 'left',
                'commentHtml' => true,
                'comment' => '
                    <button
                        type="button"
                        class="btn btn-primary"
                        style="margin-top:8px;"
                        onclick="window.payMyDineFiskalyCreateClient(this)"
                    >
                        Create TSE Client
                    </button>

                    <div style="margin-top:8px;color:#666;">
                        Creates or reconnects the Fiskaly TSE client automatically. After success, the Client ID field is filled. Then click Save.
                    </div>

                    <script>
                    window.payMyDineFiskalyCreateClient = async function(btn) {
                        try {
                            btn.disabled = true;
                            var oldText = btn.innerText;
                            btn.innerText = "Creating...";

                            const response = await fetch(window.location.origin + "/admin/fiskaly/create-client-ajax", {
                                method: "POST",
                                headers: {
                                    "X-Requested-With": "XMLHttpRequest",
                                    "Accept": "application/json",
                                    "Content-Type": "application/json",
                                    "X-CSRF-TOKEN": (
                                        document.querySelector(\'meta[name="csrf-token"]\')?.getAttribute("content") || ""
                                    )
                                },
                                body: JSON.stringify({})
                            });

                            const raw = await response.text();
                            let data = {};
                            try {
                                data = JSON.parse(raw);
                            } catch (e) {
                                throw new Error("Invalid server response: " + raw.substring(0, 300));
                            }

                            if (!response.ok || !data.ok) {
                                throw new Error(data.message || ("HTTP " + response.status));
                            }

                            var input =
                                document.querySelector(\'input[name="setting[fiskaly_client_id]"]\') ||
                                document.querySelector(\'#form-field-setting-fiskaly-client-id\') ||
                                document.querySelector(\'input[name="fiskaly_client_id"]\') ||
                                document.querySelector(\'input[name="settings[fiskaly_client_id]"]\') ||
                                document.querySelector(\'input[name="setting[fiskaly_client_id]"]\') ||
                                document.querySelector(\'input[id*="fiskaly-client-id"]\') ||
                                document.querySelector(\'input[id*="fiskaly_client_id"]\');

                            if (!input) {
                                throw new Error("Client ID input not found on page.");
                            }

                            input.value = data.client_id || "";
                            input.dispatchEvent(new Event("input", { bubbles: true }));
                            input.dispatchEvent(new Event("change", { bubbles: true }));

                            alert("TSE client ready: " + data.client_id + "

Now click Save.");

                        } catch (err) {
                            alert("Create TSE Client failed: " + err.message);
                            console.error(err);
                        } finally {
                            btn.disabled = false;
                            btn.innerText = "Create TSE Client";
                        }
                    };
                    </script>
                ',
            ],

            'fiskaly_cash_register_id' => [
                'label' => 'Cash Register ID',
                'type' => 'text',
                'span' => 'right',
                'comment' => 'Example: POS-1',
            ],

