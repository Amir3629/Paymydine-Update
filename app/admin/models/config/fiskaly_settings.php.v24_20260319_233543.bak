        'fields' => [
            'fiskaly_setup_guide' => [
                'label' => 'German TSE / Fiskaly Setup Guide',
                'type' => 'partial',
                'commentHtml' => true,
                'span' => 'full',
                'comment' => '
                    <div style="background:#f8fafc;border:1px solid #dbe3ef;border-radius:12px;padding:16px 18px;margin-bottom:16px;line-height:1.65;">
                        <div style="font-size:18px;font-weight:700;margin-bottom:8px;">Fiskaly / TSE – Quick setup</div>
                        <div style="margin-bottom:10px;color:#334155;">
                            This section connects your restaurant to the German Fiskaly SIGN DE / TSE system for compliant receipts and fiscal signing.
                        </div>
                        <ol style="padding-left:20px;margin:0 0 10px 0;color:#334155;">
                            <li>Create a Fiskaly account and get your API credentials.</li>
                            <li>Fill the fields below: API Key, API Secret, Organization ID, and Cash Register ID.</li>
                            <li>Click <strong>Save</strong>.</li>
                            <li>Click <strong>Create TSE Client</strong> to let the system create or connect the TSE client automatically.</li>
                            <li>Click <strong>Save</strong> again after the Client ID is filled.</li>
                        </ol>
                        <div style="margin-top:8px;">
                            <a href="https://www.fiskaly.com/" target="_blank" rel="noopener noreferrer" style="font-weight:600;">
                                Open Fiskaly website
