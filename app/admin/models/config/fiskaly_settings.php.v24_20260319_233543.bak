                                Open Fiskaly developer docs
                            </a>
                        </div>
                        <div style="margin-top:10px;color:#64748b;font-size:13px;">
                            Note: Use <strong>Test</strong> while onboarding. Switch to <strong>Live</strong> only after you have real production credentials from Fiskaly.
                        </div>
                    </div>
                ',
            ],
            'fiskaly_is_enabled' => [
                'label' => 'Enable Fiskaly / TSE',
                'type' => 'switch',
                'default' => 0,
                'comment' => 'Enable SIGN DE / TSE signing for this restaurant tenant.',
