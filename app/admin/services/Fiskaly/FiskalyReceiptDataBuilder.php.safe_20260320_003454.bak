<?php

namespace Admin\Services\Fiskaly;

use Illuminate\Support\Facades\DB;

class FiskalyReceiptDataBuilder
{
    public function buildForOrder(int $orderId): array
    {
        $order = DB::table('orders')->where('order_id', $orderId)->first();
        $items = DB::table('order_menus')->where('order_id', $orderId)->get();

        $paymentRaw = strtolower((string)($order->payment ?? 'cash'));
        $paymentType = in_array($paymentRaw, ['cash', 'cod', 'bar', 'cash_on_delivery'], true) ? 'CASH' : 'NON_CASH';

        $lineItems = [];
        foreach ($items as $item) {
            $qty = (float)($item->quantity ?? 0);
            $price = (float)($item->price ?? 0);
            $subtotal = (float)($item->subtotal ?? ($qty * $price));

            $lineItems[] = [
                'text' => (string)($item->name ?? 'Item'),
                'quantity' => $qty > 0 ? $qty : 1.0,
                'price_per_unit' => round($price, 2),
                'amount' => round($subtotal, 2),
                'vat_rate' => 0,
            ];
        }

        $total = round((float)($order->order_total ?? 0), 2);

        return [
            'receipt_type' => 'RECEIPT',
            'schema' => [
                'standard_v1' => [
                    'receipt' => [
                        'type' => 'RECEIPT',
                        'currency_code' => 'EUR',
                        'buyer' => [],
                        'line_items' => $lineItems,
                        'payments' => [[
                            'type' => $paymentType,
                            'amount_per_payment_type' => $total,
                        ]],
                        'amounts_per_vat_rate' => [[
                            'vat_rate' => 0,
                            'amount' => $total,
                        ]],
                    ],
                ],
            ],
            'meta' => [
                'order_id' => $orderId,
                'order_total' => $total,
                'payment' => (string)($order->payment ?? ''),
                'items_count' => $items->count(),
            ],
        ];
    }
}
