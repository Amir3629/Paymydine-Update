<?php

namespace Admin\Services\Fiskaly;

require_once __DIR__.'/FiskalyApiClient.php';
require_once app_path('admin/models/Fiskaly_configs_model.php');

use Admin\Models\Fiskaly_configs_model;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Str;

class FiskalyProvisionService
{
    public function ensureClientExists(Fiskaly_configs_model $cfg, bool $force = false): array
    {
        if (!$cfg->is_enabled) {
            return ['ok' => false, 'skipped' => true, 'reason' => 'disabled'];
        }

        if (
            empty($cfg->api_key) ||
            empty($cfg->api_secret) ||
            empty($cfg->cash_register_id)
        ) {
            return ['ok' => false, 'skipped' => true, 'reason' => 'missing_required_config'];
        }

        $meta = is_array($cfg->meta) ? $cfg->meta : [];
        $adminPin = (string)($meta['admin_pin'] ?? '12345');
        $timeAdminPin = (string)($meta['time_admin_pin'] ?? '67890');

        $cfg->meta = array_merge($meta, [
            'admin_pin' => $adminPin,
            'time_admin_pin' => $timeAdminPin,
            'provisioning_status' => 'started',
            'provisioning_step' => 'boot',
            'last_error' => null,
        ]);
        $cfg->saveQuietly();

        $api = new FiskalyApiClient($cfg);

        try {
            // STEP 1: ensure TSS exists
            if (empty($cfg->tss_id) || $force) {
                $cfg->meta = array_merge((array)$cfg->meta, [
                    'provisioning_step' => 'create_tss',
                ]);
                $cfg->saveQuietly();

                $tssResult = $api->createTss([
                    'description' => 'paymydine loc-'.$cfg->location_id.' '.$cfg->cash_register_id,
                    'admin_pin' => $adminPin,
                    'time_admin_pin' => $timeAdminPin,
                ]);

                $cfg->tss_id = $tssResult['_id'] ?? $tssResult['id'] ?? $tssResult['tss_id'] ?? $cfg->tss_id;
                $cfg->meta = array_merge((array)$cfg->meta, [
                    'puk' => $tssResult['puk'] ?? ((array)$cfg->meta)['puk'] ?? null,
                    'create_tss_response' => $tssResult,
                    'provisioning_status' => 'tss_created',
                ]);
                $cfg->saveQuietly();
            }

            if (empty($cfg->tss_id)) {
                throw new \RuntimeException('TSS creation did not return tss_id');
            }

            // STEP 2: read TSS state
            $cfg->meta = array_merge((array)$cfg->meta, [
                'provisioning_step' => 'get_tss',
            ]);
            $cfg->saveQuietly();

            $tss = $api->getTss((string)$cfg->tss_id);
            $tssState = (string)($tss['state'] ?? '');

            $cfg->meta = array_merge((array)$cfg->meta, [
                'tss_state' => $tssState,
                'get_tss_response' => $tss,
            ]);
            $cfg->saveQuietly();

            // STEP 3: CREATED -> UNINITIALIZED
            if ($tssState === 'CREATED') {
                $cfg->meta = array_merge((array)$cfg->meta, [
                    'provisioning_step' => 'set_uninitialized',
                ]);
                $cfg->saveQuietly();

                $tss = $api->updateTssState((string)$cfg->tss_id, 'UNINITIALIZED');
                $tssState = (string)($tss['state'] ?? 'UNINITIALIZED');

                $cfg->meta = array_merge((array)$cfg->meta, [
                    'tss_state' => $tssState,
                    'set_uninitialized_response' => $tss,
                    'provisioning_status' => 'tss_uninitialized',
                ]);
                $cfg->saveQuietly();
            }

            // STEP 4: try change admin pin if TSS is UNINITIALIZED
            if ($tssState === 'UNINITIALIZED') {
                try {
                    $cfg->meta = array_merge((array)$cfg->meta, [
                        'provisioning_step' => 'change_admin_pin',
                    ]);
                    $cfg->saveQuietly();

                    $pinResult = $api->changeAdminPin((string)$cfg->tss_id, $adminPin, $timeAdminPin);

                    $cfg->meta = array_merge((array)$cfg->meta, [
                        'change_admin_pin_response' => $pinResult,
                        'provisioning_status' => 'admin_pin_set',
                    ]);
                    $cfg->saveQuietly();
                } catch (\Throwable $e) {
                    Log::warning('[Fiskaly] changeAdminPin skipped/failed, continuing', [
                        'location_id' => $cfg->location_id,
                        'tss_id' => $cfg->tss_id,
                        'message' => $e->getMessage(),
                    ]);

                    $cfg->meta = array_merge((array)$cfg->meta, [
                        'change_admin_pin_error' => $e->getMessage(),
                    ]);
                    $cfg->saveQuietly();
                }
            }

            // STEP 5: admin auth
            $cfg->meta = array_merge((array)$cfg->meta, [
                'provisioning_step' => 'admin_auth',
            ]);
            $cfg->saveQuietly();

            $adminAuth = $api->adminAuth((string)$cfg->tss_id, $adminPin, $timeAdminPin);
            $adminToken = $adminAuth['access_token'] ?? null;

            $cfg->meta = array_merge((array)$cfg->meta, [
                'admin_auth_response' => $adminAuth,
                'provisioning_status' => 'admin_authenticated',
            ]);
            $cfg->saveQuietly();

            // STEP 6: INITIALIZE if needed
            $tss = $api->getTss((string)$cfg->tss_id);
            $tssState = (string)($tss['state'] ?? '');

            if ($tssState === 'UNINITIALIZED') {
                $cfg->meta = array_merge((array)$cfg->meta, [
                    'provisioning_step' => 'set_initialized',
                ]);
                $cfg->saveQuietly();

                $tss = $api->updateTssState((string)$cfg->tss_id, 'INITIALIZED');
                $tssState = (string)($tss['state'] ?? 'INITIALIZED');

                $cfg->meta = array_merge((array)$cfg->meta, [
                    'tss_state' => $tssState,
                    'set_initialized_response' => $tss,
                    'provisioning_status' => 'tss_initialized',
                ]);
                $cfg->saveQuietly();
            }

            // STEP 7: create client if missing
            if (!$force && !empty($cfg->client_id)) {
                return [
                    'ok' => true,
                    'skipped' => true,
                    'reason' => 'already_exists',
                    'tss_id' => $cfg->tss_id,
                    'client_id' => $cfg->client_id,
                ];
            }

            $cfg->meta = array_merge((array)$cfg->meta, [
                'provisioning_step' => 'create_client',
            ]);
            $cfg->saveQuietly();

            $clientId = (string) Str::uuid();
            $serialNumber = 'paymydine-loc'.$cfg->location_id.'-'.preg_replace('/[^A-Za-z0-9\-_]/', '-', (string)$cfg->cash_register_id).'-'.date('YmdHis');

            $clientResult = $api->createClient((string)$cfg->tss_id, $clientId, [
                'serial_number' => $serialNumber,
                'cash_register_id' => (string)$cfg->cash_register_id,
                'admin_pin' => $adminPin,
                'time_admin_pin' => $timeAdminPin,
            ], $adminToken);

            $cfg->client_id = $clientResult['_id'] ?? $clientResult['id'] ?? $clientId;
            $cfg->meta = array_merge((array)$cfg->meta, [
                'client_serial_number' => $serialNumber,
                'create_client_response' => $clientResult,
                'provisioning_status' => 'active',
                'provisioning_step' => 'done',
                'provisioned_at' => now()->toDateTimeString(),
                'last_error' => null,
            ]);
            $cfg->saveQuietly();

            Log::info('[Fiskaly] provisioning complete', [
                'location_id' => $cfg->location_id,
                'tss_id' => $cfg->tss_id,
                'client_id' => $cfg->client_id,
            ]);

            return [
                'ok' => true,
                'tss_id' => $cfg->tss_id,
                'client_id' => $cfg->client_id,
                'tss_state' => $tssState,
                'client_response' => $clientResult,
            ];
        } catch (\Throwable $e) {
            $cfg->last_error = $e->getMessage();
            $cfg->meta = array_merge((array)$cfg->meta, [
                'provisioning_status' => 'failed',
                'provisioning_step' => 'failed',
                'last_error' => $e->getMessage(),
            ]);
            $cfg->saveQuietly();

            Log::error('[Fiskaly] provisioning failed', [
                'location_id' => $cfg->location_id,
                'message' => $e->getMessage(),
            ]);

            throw $e;
        }
    }
}
