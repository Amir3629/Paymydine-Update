<?php

namespace Admin\Services\Fiskaly;

use Admin\Models\Fiskaly_configs_model;
use Illuminate\Support\Facades\Http;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Str;

class FiskalyApiClient
{
    protected Fiskaly_configs_model $config;
    protected string $middlewareBaseUrl = 'https://kassensichv-middleware.fiskaly.com/api/v2';
    protected string $backendBaseUrl = 'https://kassensichv.fiskaly.com/api/v2';

    public function __construct(Fiskaly_configs_model $config)
    {
        $this->config = $config;
    }

    public function authenticate(): array
    {
        $res = Http::timeout(30)
            ->acceptJson()
            ->post($this->middlewareBaseUrl.'/auth', [
                'api_key' => (string)$this->config->api_key,
                'api_secret' => (string)$this->config->api_secret,
            ]);

        if (!$res->successful()) {
            throw new \RuntimeException('Fiskaly auth failed: HTTP '.$res->status().' BODY: '.$res->body());
        }

        $json = $res->json() ?: [];
        if (empty($json['access_token'])) {
            throw new \RuntimeException('Fiskaly auth failed: missing access_token');
        }

        return $json;
    }

    protected function curlJson(string $method, string $url, ?string $token = null, array $payload = [], int $timeout = 45): array
    {
        $jsonBody = json_encode($payload, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
        if ($jsonBody === false) {
            throw new \RuntimeException('Fiskaly JSON encode failed: '.json_last_error_msg());
        }

        Log::info('[Fiskaly][curl] request', [
            'method' => $method,
            'url' => $url,
            'payload' => $payload,
            'json' => $jsonBody,
        ]);

        $headers = [
            'Accept: application/json',
            'Content-Type: application/json',
            'Content-Length: '.strlen($jsonBody),
        ];

        if ($token) {
            $headers[] = 'Authorization: Bearer '.$token;
        }

        $ch = curl_init($url);
        curl_setopt_array($ch, [
            CURLOPT_CUSTOMREQUEST => strtoupper($method),
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_HTTPHEADER => $headers,
            CURLOPT_POSTFIELDS => $jsonBody,
            CURLOPT_TIMEOUT => $timeout,
            CURLOPT_CONNECTTIMEOUT => 15,
            CURLOPT_HEADER => true,
        ]);

        $raw = curl_exec($ch);

        if ($raw === false) {
            $err = curl_error($ch);
            curl_close($ch);
            throw new \RuntimeException('Fiskaly cURL failed: '.$err);
        }

        $status = curl_getinfo($ch, CURLINFO_HTTP_CODE);
        $headerSize = curl_getinfo($ch, CURLINFO_HEADER_SIZE);
        $respHeaders = substr($raw, 0, $headerSize);
        $body = substr($raw, $headerSize);

        curl_close($ch);

        Log::info('[Fiskaly][curl] response', [
            'method' => $method,
            'url' => $url,
            'status' => $status,
            'headers' => $respHeaders,
            'body' => $body,
        ]);

        if ($status < 200 || $status >= 300) {
            throw new \RuntimeException("Fiskaly request failed: {$method} {$url} HTTP {$status} BODY: ".$body);
        }

        $json = json_decode($body, true);
        return is_array($json) ? $json : [];
    }

    public function getTss(string $tssId): array
    {
        $auth = $this->authenticate();
        return $this->curlJson('GET', $this->middlewareBaseUrl.'/tss/'.$tssId, $auth['access_token'], [], 45);
    }

    public function createTss(array $payload): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $variants = [
            ['POST', $this->middlewareBaseUrl.'/tss'],
            ['PUT',  $this->middlewareBaseUrl.'/tss/'.(string)Str::uuid()],
        ];

        $last = null;
        foreach ($variants as [$method, $url]) {
            try {
                return $this->curlJson($method, $url, $token, $payload, 60);
            } catch (\Throwable $e) {
                $last = $e->getMessage();
            }
        }

        throw new \RuntimeException('createTss failed: '.$last);
    }

    public function updateTssState(string $tssId, string $state): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $variants = [
            ['PATCH', $this->middlewareBaseUrl.'/tss/'.$tssId, ['state' => $state]],
            ['PUT',   $this->middlewareBaseUrl.'/tss/'.$tssId, ['state' => $state]],
        ];

        $last = null;
        foreach ($variants as [$method, $url, $payload]) {
            try {
                return $this->curlJson($method, $url, $token, $payload, 45);
            } catch (\Throwable $e) {
                $last = $e->getMessage();
            }
        }

        throw new \RuntimeException('updateTssState('.$state.') failed: '.$last);
    }

    public function changeAdminPinWithPuk(string $tssId, string $adminPuk, string $newAdminPin, ?string $newTimeAdminPin = null): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $payloads = [
            array_filter([
                'admin_puk' => $adminPuk,
                'new_admin_pin' => $newAdminPin,
                'new_time_admin_pin' => $newTimeAdminPin,
            ]),
            array_filter([
                'admin_puk' => $adminPuk,
                'admin_pin' => $newAdminPin,
                'time_admin_pin' => $newTimeAdminPin,
            ]),
        ];

        $variants = [
            ['PATCH', $this->middlewareBaseUrl.'/tss/'.$tssId.'/admin'],
            ['PUT',   $this->middlewareBaseUrl.'/tss/'.$tssId.'/admin'],
            ['POST',  $this->middlewareBaseUrl.'/tss/'.$tssId.'/admin'],
        ];

        $last = null;
        foreach ($variants as [$method, $url]) {
            foreach ($payloads as $payload) {
                try {
                    return $this->curlJson($method, $url, $token, $payload, 45);
                } catch (\Throwable $e) {
                    $last = $e->getMessage();
                }
            }
        }

        throw new \RuntimeException('changeAdminPinWithPuk failed: '.$last);
    }

    public function adminAuth(string $tssId, string $adminPin, ?string $timeAdminPin = null): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $payloads = [
            ['admin_pin' => $adminPin],
            array_filter([
                'admin_pin' => $adminPin,
                'time_admin_pin' => $timeAdminPin,
            ]),
        ];

        $last = null;
        foreach ($payloads as $payload) {
            try {
                $result = $this->curlJson('POST', $this->middlewareBaseUrl.'/tss/'.$tssId.'/admin/auth', $token, $payload, 45);
                return $result ?: ['ok' => true];
            } catch (\Throwable $e) {
                $last = $e->getMessage();
            }
        }

        throw new \RuntimeException('adminAuth failed: '.$last);
    }

    public function createClient(string $tssId, string $clientId, $payload, ?string $adminToken = null): array
    {
        $serialNumber = null;

        if (is_array($payload)) {
            $serialNumber = $payload['serial_number'] ?? null;
        } elseif (is_string($payload)) {
            $serialNumber = $payload;
        }

        if (!$serialNumber) {
            throw new \RuntimeException('createClient failed: missing serial_number');
        }

        $auth = $this->authenticate();
        $token = $auth['access_token'] ?? null;
        if (!$token) {
            throw new \RuntimeException('createClient failed: missing access token');
        }

        return $this->curlJson('PUT', $this->middlewareBaseUrl.'/tss/'.$tssId.'/client/'.$clientId, $token, [
            'serial_number' => (string)$serialNumber,
        ], 45);
    }

    public function upsertTransaction(string $txId, array $payload): array
    {
        $txRevision = (int)($payload['tx_revision'] ?? 1);
        unset($payload['tx_revision']);

        if (empty($payload['receipt_type'])) {
            $payload['receipt_type'] = 'RECEIPT';
        }

        $auth = $this->authenticate();
        $token = $auth['access_token'] ?? null;

        if (!$token) {
            throw new \RuntimeException('Fiskaly auth failed: missing access_token after auth');
        }

        $url = $this->middlewareBaseUrl.'/tss/'.$this->config->tss_id.'/tx/'.$txId.'?tx_revision='.$txRevision;
        return $this->curlJson('PUT', $url, $token, $payload, 45);
    }
}
