<?php

namespace Admin\Services\Fiskaly;

use Admin\Models\Fiskaly_configs_model;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Str;

class FiskalyProvisionService
{
    protected function saveMeta(Fiskaly_configs_model $cfg, array $merge): void
    {
        $cfg->meta = array_merge(is_array($cfg->meta) ? $cfg->meta : [], $merge);
        $cfg->saveQuietly();
    }

    protected function requireTssState(FiskalyApiClient $api, Fiskaly_configs_model $cfg, string $expected, string $context): array
    {
        $tss = $api->getTss((string)$cfg->tss_id);
        $actual = (string)($tss['state'] ?? '');

        $this->saveMeta($cfg, [
            'tss_state' => $actual,
            'last_tss_read_context' => $context,
            'last_tss_read_response' => $tss,
        ]);

        if ($actual !== $expected) {
            throw new \RuntimeException($context.' failed: expected TSS state '.$expected.', got '.$actual);
        }

        return $tss;
    }

    public function ensureClientExists(Fiskaly_configs_model $cfg, bool $force = false): array
    {
        if (!$cfg->is_enabled) {
            return ['ok' => false, 'skipped' => true, 'reason' => 'disabled'];
        }

        if (empty($cfg->api_key) || empty($cfg->api_secret) || empty($cfg->cash_register_id)) {
            return ['ok' => false, 'skipped' => true, 'reason' => 'missing_required_config'];
        }

        require_once __DIR__.'/FiskalyApiClient.php';

        $meta = is_array($cfg->meta) ? $cfg->meta : [];
        $adminPin = (string)($meta['admin_pin'] ?? '12345');
        $adminPuk = (string)($meta['admin_puk'] ?? '');

        $this->saveMeta($cfg, [
            'admin_pin' => $adminPin,
            'provisioning_status' => 'started',
            'last_error' => null,
        ]);

        $api = new FiskalyApiClient($cfg);
        $adminToken = null;

        try {
            if (empty($cfg->tss_id)) {
                $tss = $api->createTss([
                    'metadata' => [
                        'paymydine_location_id' => (string)$cfg->location_id,
                        'paymydine_cash_register_id' => (string)$cfg->cash_register_id,
                    ],
                ]);

                $cfg->tss_id = $tss['_id'] ?? $tss['id'] ?? $tss['tss_id'] ?? null;
                $adminPuk = (string)($tss['admin_puk'] ?? $tss['puk'] ?? '');
                $this->saveMeta($cfg, [
                    'create_tss_response' => $tss,
                    'admin_puk' => $adminPuk ?: null,
                    'provisioning_status' => 'tss_created',
                ]);
                $cfg->saveQuietly();
            }

            if (empty($cfg->tss_id)) {
                throw new \RuntimeException('Missing tss_id after createTss');
            }

            $tss = $api->getTss((string)$cfg->tss_id);
            $state = (string)($tss['state'] ?? '');

            $this->saveMeta($cfg, [
                'get_tss_response' => $tss,
                'tss_state' => $state,
            ]);

            if ($state === 'CREATED' && !$adminPuk) {
                $recover = $api->createTss([
                    'metadata' => [
                        'paymydine_location_id' => (string)$cfg->location_id,
                        'paymydine_cash_register_id' => (string)$cfg->cash_register_id,
                    ],
                ], (string)$cfg->tss_id);

                $adminPuk = (string)($recover['admin_puk'] ?? $recover['puk'] ?? '');
                $this->saveMeta($cfg, [
                    'recover_admin_puk_response' => $recover,
                    'admin_puk' => $adminPuk ?: null,
                ]);
            }

            if ($state === 'CREATED') {
                $setUninitialized = $api->updateTssState((string)$cfg->tss_id, 'UNINITIALIZED');

                $this->saveMeta($cfg, [
                    'set_uninitialized_response' => $setUninitialized,
                ]);

                $tss = $this->requireTssState($api, $cfg, 'UNINITIALIZED', 'set UNINITIALIZED');
                $state = (string)($tss['state'] ?? '');
            }

            if ($state === 'UNINITIALIZED') {
                if (!$adminPuk) {
                    $adminPuk = (string)($tss['admin_puk'] ?? '');
                }

                if (!$adminPuk) {
                    throw new \RuntimeException('Missing admin_puk while TSS is UNINITIALIZED/CREATED');
                }

                $pinChangedAt = $meta['admin_pin_changed_at'] ?? null;
                if (!$pinChangedAt) {
                    $pinResult = $api->changeAdminPin((string)$cfg->tss_id, $adminPuk, $adminPin);

                    $this->saveMeta($cfg, [
                        'change_admin_pin_response' => $pinResult,
                        'admin_pin_changed_at' => now()->toDateTimeString(),
                        'admin_puk' => $adminPuk,
                    ]);
                }

                $adminAuth = $api->adminAuth((string)$cfg->tss_id, $adminPin);
                $adminToken = $adminAuth['access_token'] ?? null;

                if (!$adminToken) {
                    throw new \RuntimeException('adminAuth failed: missing access_token');
                }

                $this->saveMeta($cfg, [
                    'admin_auth_response' => $adminAuth,
                ]);

                $setInitialized = $api->updateTssState((string)$cfg->tss_id, 'INITIALIZED');

                $this->saveMeta($cfg, [
                    'set_initialized_response' => $setInitialized,
                ]);

                $tss = $this->requireTssState($api, $cfg, 'INITIALIZED', 'set INITIALIZED');
                $state = (string)($tss['state'] ?? '');
            }

            if ($state !== 'INITIALIZED') {
                throw new \RuntimeException('TSS is not INITIALIZED; current state='.$state);
            }

            if (!$adminToken) {
                $adminAuth = $api->adminAuth((string)$cfg->tss_id, $adminPin);
                $adminToken = $adminAuth['access_token'] ?? null;

                if (!$adminToken) {
                    throw new \RuntimeException('adminAuth failed before client create: missing access_token');
                }

                $this->saveMeta($cfg, [
                    'admin_auth_response' => $adminAuth,
                ]);
            }

            if (!empty($cfg->client_id)) {
                return [
                    'ok' => true,
                    'skipped' => true,
                    'reason' => 'already_exists',
                    'tss_id' => $cfg->tss_id,
                    'client_id' => $cfg->client_id,
                    'tss_state' => $state,
                ];
            }

            $clientId = (string) Str::uuid();
            $serialNumber = 'paymydine-loc'.$cfg->location_id.'-'.preg_replace('/[^A-Za-z0-9\-_]/', '-', (string)$cfg->cash_register_id).'-'.date('YmdHis');

            $client = $api->createClient((string)$cfg->tss_id, $clientId, [
                'serial_number' => $serialNumber,
                'metadata' => [
                    'paymydine_location_id' => (string)$cfg->location_id,
                    'paymydine_cash_register_id' => (string)$cfg->cash_register_id,
                ],
            ], $adminToken);

            $cfg->client_id = $client['_id'] ?? $client['id'] ?? $clientId;

            $this->saveMeta($cfg, [
                'client_serial_number' => $serialNumber,
                'create_client_response' => $client,
                'provisioning_status' => 'active',
                'provisioned_at' => now()->toDateTimeString(),
                'last_error' => null,
            ]);

            $cfg->saveQuietly();

            try {
                $logout = $api->adminLogout((string)$cfg->tss_id, $adminToken);
                $this->saveMeta($cfg, [
                    'admin_logout_response' => $logout,
                ]);
            } catch (\Throwable $logoutError) {
                $this->saveMeta($cfg, [
                    'admin_logout_error' => $logoutError->getMessage(),
                ]);
            }

            return [
                'ok' => true,
                'tss_id' => $cfg->tss_id,
                'client_id' => $cfg->client_id,
                'tss_state' => $state,
            ];
        } catch (\Throwable $e) {
            $cfg->last_error = $e->getMessage();
            $this->saveMeta($cfg, [
                'provisioning_status' => 'failed',
                'last_error' => $e->getMessage(),
            ]);
            $cfg->saveQuietly();

            Log::error('[Fiskaly] provisioning failed', [
                'location_id' => $cfg->location_id,
                'message' => $e->getMessage(),
            ]);

            throw $e;
        }
    }
}
