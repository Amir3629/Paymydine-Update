<?php

namespace Admin\Services\Fiskaly;

use Admin\Models\Fiskaly_configs_model;

class FiskalyConfigResolver
{
    public function forLocation(int $locationId = 1): ?Fiskaly_configs_model
    {
        return Fiskaly_configs_model::where('location_id', $locationId)->first();
    }

    public function isEnabledForLocation(int $locationId = 1): bool
    {
        $cfg = $this->forLocation($locationId);
        return $cfg && $cfg->is_enabled && !empty($cfg->api_key) && !empty($cfg->api_secret)
            && !empty($cfg->tss_id) && !empty($cfg->client_id);
    }
}
