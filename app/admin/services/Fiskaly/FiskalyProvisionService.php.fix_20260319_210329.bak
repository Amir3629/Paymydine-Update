<?php

namespace Admin\Services\Fiskaly;

use Admin\Models\Fiskaly_configs_model;
use Illuminate\Support\Facades\Log;

class FiskalyProvisionService
{
    public function ensureClientExists(Fiskaly_configs_model $cfg, bool $force = false): array
    {
        if (!$cfg->is_enabled) {
            return ['ok' => false, 'skipped' => true, 'reason' => 'disabled'];
        }

        if (!$force && !empty($cfg->client_id)) {
            return [
                'ok' => true,
                'skipped' => true,
                'reason' => 'already_exists',
                'client_id' => $cfg->client_id,
            ];
        }

        if (
            empty($cfg->api_key) ||
            empty($cfg->api_secret) ||
            empty($cfg->tss_id) ||
            empty($cfg->cash_register_id)
        ) {
            return ['ok' => false, 'skipped' => true, 'reason' => 'missing_required_config'];
        }

        $api = new FiskalyApiClient($cfg);

        $result = $api->createClient([
            'cash_register_id' => (string)$cfg->cash_register_id,
            'admin_pin' => $cfg->fiskaly_admin_pin ? (string)$cfg->fiskaly_admin_pin : null,
            'time_admin_pin' => $cfg->fiskaly_time_admin_pin ? (string)$cfg->fiskaly_time_admin_pin : null,
        ]);

        $clientId = $result['client_id'] ?? $result['id'] ?? null;

        if (!$clientId) {
            Log::error('[Fiskaly] createClient succeeded but missing client_id', [
                'location_id' => $cfg->location_id,
                'tss_id' => $cfg->tss_id,
                'response' => $result,
            ]);

            throw new \RuntimeException('Fiskaly client created but client_id missing in response');
        }

        $cfg->client_id = (string)$clientId;
        $cfg->saveQuietly();

        Log::info('[Fiskaly] client auto-created', [
            'location_id' => $cfg->location_id,
            'tss_id' => $cfg->tss_id,
            'client_id' => $cfg->client_id,
            'forced' => $force,
        ]);

        return [
            'ok' => true,
            'client_id' => $cfg->client_id,
            'response' => $result,
        ];
    }
}
