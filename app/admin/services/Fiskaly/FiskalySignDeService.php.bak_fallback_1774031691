    {
        try {
            if (!$order) {
                return null;
            }

            $rows = [];

            if ($items && is_iterable($items)) {
                foreach ($items as $item) {
                    $name = (string)($item->name ?? $item['name'] ?? 'Item');
                    $qty = (string)($item->quantity ?? $item['quantity'] ?? 1);
                    $unit = (string)($item->price ?? $item['price'] ?? 0);
                    $total = (string)(
                        $item->total_price
                        ?? $item['total_price']
                        ?? (
                            ((float)($item->quantity ?? $item['quantity'] ?? 1))
                            * ((float)($item->price ?? $item['price'] ?? 0))
                        )
                    );

                    $rows[] = [
                        'name' => $name,
                        'quantity' => $qty,
                        'unit_price' => $unit,
                        'total_price' => $total,
                        'vat_rate' => '0',
                    ];
                }
            }

            if (empty($rows) && !empty($order->cart)) {
                $decodedCart = json_decode((string)$order->cart, true);
                if (is_array($decodedCart)) {
                    foreach ($decodedCart as $item) {
                        if (!is_array($item)) {
                            continue;
                        }

                        $name = (string)($item['name'] ?? 'Item');
                        $qty = (string)($item['quantity'] ?? 1);
                        $unit = (string)($item['price'] ?? 0);
                        $total = (string)(
                            $item['total_price']
                            ?? (((float)($item['quantity'] ?? 1)) * ((float)($item['price'] ?? 0)))
                        );

                        $rows[] = [
                            'name' => $name,
                            'quantity' => $qty,
                            'unit_price' => $unit,
                            'total_price' => $total,
                            'vat_rate' => '0',
                        ];
                    }
                }
            }

            $payload = [
                'currency' => 'EUR',
                'payment_type' => 'CASH',
                'total_amount' => (string)($order->order_total ?? '0'),
                'items' => $rows,
            ];

            return json_encode($payload, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
        } catch (\Throwable $e) {
            return null;
        }
    }

    private function pmdForceNormalizeTxPayloadV1($payload, $txModel = null, $order = null, $items = null): array
    {
        if (!is_array($payload)) {
            $payload = [];
        }

        if (!isset($payload['schema']) || !is_array($payload['schema'])) {
            $payload['schema'] = [];
        }

        if (!isset($payload['schema']['raw']) || !is_array($payload['schema']['raw'])) {
            $payload['schema']['raw'] = [];
        }

        if (empty($payload['schema']['raw']['process_type'])) {
            $payload['schema']['raw']['process_type'] = 'RECEIPT';
        }

        $processData = null;

        if (!empty($payload['schema']['raw']['process_data'])) {
            $processData = (string)$payload['schema']['raw']['process_data'];
        }

        if (!$processData && $txModel && !empty($txModel->request_payload)) {
            $decoded = json_decode((string)$txModel->request_payload, true);
            if (is_array($decoded)) {
                $processData = $decoded['schema']['raw']['process_data'] ?? null;
            }
        }

        if (!$processData && $txModel && !empty($txModel->response_payload)) {
            $decoded = json_decode((string)$txModel->response_payload, true);
            if (is_array($decoded)) {
                $processData = $decoded['schema']['raw']['process_data'] ?? null;
            }
        }

        if (!$processData && $txModel && !empty($txModel->meta)) {
            $decoded = json_decode((string)$txModel->meta, true);
            if (is_array($decoded)) {
                $processData =
                    $decoded['responses']['update']['schema']['raw']['process_data']
                    ?? $decoded['responses']['start']['schema']['raw']['process_data']
                    ?? null;
            }
        }

        if (!$processData) {
            $json = $this->pmdForceProcessDataJsonV1($order, $items);
            if ($json) {
                $processData = base64_encode($json);
            }
        }

        if ($processData) {
            $payload['schema']['raw']['process_data'] = $processData;
        }

        if (empty($payload['client_id']) && $txModel && !empty($txModel->client_id)) {
            $payload['client_id'] = $txModel->client_id;
        }

        if (empty($payload['receipt_type'])) {
            $payload['receipt_type'] = 'RECEIPT';
        }

        return $payload;
    }

}
