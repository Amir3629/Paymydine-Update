<?php

namespace Admin\Services\Fiskaly;

use Illuminate\Support\Facades\DB;

class FiskalyReceiptPresenter
{
    public static function forOrder($orderId): array
    {
        $result = [
            'has_data' => false,
            'qr_code_data' => null,
            'tse_transaction' => null,
            'tse_start' => null,
            'tse_stop' => null,
            'tss_serial_number' => null,
            'client_serial_number' => null,
            'signature_value' => null,
            'signature_counter' => null,
            'signature_algorithm' => null,
            'public_key' => null,
            'timestamp_format' => null,
        ];

        try {
            if (!DB::getSchemaBuilder()->hasTable('fiskaly_transactions')) {
                return $result;
            }

            $row = DB::table('fiskaly_transactions')
                ->where('order_id', $orderId)
                ->orderByDesc('fiskaly_transaction_id')
                ->first();

            if (!$row) {
                return $result;
            }

            $flat = (array)$row;

            foreach ($flat as $key => $value) {
                if (!is_string($value) || $value === '') {
                    continue;
                }

                $json = json_decode($value, true);
                if (is_array($json)) {
                    $flat = array_replace_recursive($flat, self::flattenJson($json));
                }
            }

            $result['qr_code_data'] = self::pick($flat, [
                'qr_code_data',
                'response.qr_code_data',
                'transaction.qr_code_data',
                'data.qr_code_data',
            ]);

            $result['tse_transaction'] = self::pick($flat, [
                'number',
                'response.number',
                'transaction.number',
            ]);

            $result['tse_start'] = self::pick($flat, [
                'time_start',
                'response.time_start',
                'transaction.time_start',
            ]);

            $result['tse_stop'] = self::pick($flat, [
                'time_end',
                'response.time_end',
                'transaction.time_end',
            ]);

            $result['tss_serial_number'] = self::pick($flat, [
                'tss_serial_number',
                'certificate_serial',
                'response.tss_serial_number',
                'transaction.tss_serial_number',
            ]);

            $result['client_serial_number'] = self::pick($flat, [
                'client_serial_number',
                'response.client_serial_number',
                'transaction.client_serial_number',
            ]);

            $result['signature_value'] = self::pick($flat, [
                'signature.value',
                'response.signature.value',
                'transaction.signature.value',
                'signature',
            ]);

            $result['signature_counter'] = self::pick($flat, [
                'signature.counter',
                'signature_counter',
                'response.signature.counter',
                'transaction.signature.counter',
            ]);

            $result['signature_algorithm'] = self::pick($flat, [
                'signature.algorithm',
                'response.signature.algorithm',
                'transaction.signature.algorithm',
            ]);

            $result['public_key'] = self::pick($flat, [
                'signature.public_key',
                'response.signature.public_key',
                'transaction.signature.public_key',
            ]);

            $result['timestamp_format'] = self::pick($flat, [
                'log.timestamp_format',
                'response.log.timestamp_format',
                'transaction.log.timestamp_format',
            ]);

            $result['has_data'] = (bool)(
                $result['qr_code_data'] ||
                $result['tse_transaction'] ||
                $result['signature_value']
            );

            return $result;
        } catch (\Throwable $e) {
            $result['error'] = $e->getMessage();
            return $result;
        }
    }

    protected static function flattenJson(array $data, string $prefix = ''): array
    {
        $out = [];

        foreach ($data as $key => $value) {
            $full = $prefix === '' ? (string)$key : $prefix.'.'.$key;

            if (is_array($value)) {
                $out += self::flattenJson($value, $full);
            } else {
                $out[$full] = $value;
            }
        }

        return $out;
    }

    protected static function pick(array $flat, array $keys)
    {
        foreach ($keys as $key) {
            if (array_key_exists($key, $flat) && $flat[$key] !== null && $flat[$key] !== '') {
                return $flat[$key];
            }
        }

        return null;
    }
}
