<?php

namespace Admin\Services\Fiskaly;

use Admin\Models\Fiskaly_configs_model;
use Illuminate\Support\Facades\Http;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Str;

class FiskalyApiClient
{
    protected Fiskaly_configs_model $config;
    protected string $baseUrl = 'https://kassensichv-middleware.fiskaly.com/api/v2';

    public function __construct(Fiskaly_configs_model $config)
    {
        $this->config = $config;
    }

    public function authenticate(): array
    {
        $res = Http::timeout(30)
            ->acceptJson()
            ->post($this->baseUrl.'/auth', [
                'api_key' => (string)$this->config->api_key,
                'api_secret' => (string)$this->config->api_secret,
            ]);

        if (!$res->successful()) {
            throw new \RuntimeException('Fiskaly auth failed: HTTP '.$res->status().' BODY: '.$res->body());
        }

        $json = $res->json() ?: [];
        if (empty($json['access_token'])) {
            throw new \RuntimeException('Fiskaly auth failed: missing access_token');
        }

        return $json;
    }

    protected function req(string $method, string $url, ?string $token = null, array $payload = [], int $timeout = 45): array
    {
        Log::info('[Fiskaly] request', [
            'method' => $method,
            'url' => $url,
            'payload' => $payload,
        ]);

        $http = Http::timeout($timeout)->acceptJson();
        if ($token) {
            $http = $http->withToken($token);
        }

        $method = strtoupper($method);

        if ($method === 'GET') {
            $res = $http->get($url, $payload);
        } elseif ($method === 'POST') {
            $res = $http->post($url, $payload);
        } elseif ($method === 'PUT') {
            $res = $http->put($url, $payload);
        } elseif ($method === 'PATCH') {
            $res = $http->patch($url, $payload);
        } else {
            throw new \RuntimeException('Unsupported HTTP method: '.$method);
        }

        Log::info('[Fiskaly] response', [
            'method' => $method,
            'url' => $url,
            'status' => $res->status(),
            'body' => $res->body(),
        ]);

        if (!$res->successful()) {
            throw new \RuntimeException("Fiskaly request failed: {$method} {$url} HTTP {$res->status()} BODY: ".$res->body());
        }

        $json = $res->json();
        return is_array($json) ? $json : [];
    }

    public function getTss(string $tssId): array
    {
        $auth = $this->authenticate();
        return $this->req('GET', $this->baseUrl.'/tss/'.$tssId, $auth['access_token']);
    }

    public function createTss(array $payload): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $variants = [
            ['POST', $this->baseUrl.'/tss'],
            ['PUT',  $this->baseUrl.'/tss/'.(string)Str::uuid()],
        ];

        $last = null;
        foreach ($variants as [$method, $url]) {
            try {
                return $this->req($method, $url, $token, $payload, 60);
            } catch (\Throwable $e) {
                $last = $e->getMessage();
            }
        }

        throw new \RuntimeException('createTss failed: '.$last);
    }

    public function updateTssState(string $tssId, string $state): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $variants = [
            ['PUT',   $this->baseUrl.'/tss/'.$tssId, ['state' => $state]],
            ['PATCH', $this->baseUrl.'/tss/'.$tssId, ['state' => $state]],
            ['PUT',   $this->baseUrl.'/tss/'.$tssId, ['admin' => ['state' => $state]]],
            ['PATCH', $this->baseUrl.'/tss/'.$tssId, ['admin' => ['state' => $state]]],
        ];

        $last = null;
        foreach ($variants as [$method, $url, $payload]) {
            try {
                return $this->req($method, $url, $token, $payload, 45);
            } catch (\Throwable $e) {
                $last = $e->getMessage();
            }
        }

        throw new \RuntimeException('updateTssState('.$state.') failed: '.$last);
    }

    public function changeAdminPin(string $tssId, string $adminPin, string $timeAdminPin): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $variants = [
            ['POST',  $this->baseUrl.'/tss/'.$tssId.'/admin/pin', ['admin_pin' => $adminPin, 'time_admin_pin' => $timeAdminPin]],
            ['PUT',   $this->baseUrl.'/tss/'.$tssId.'/admin/pin', ['admin_pin' => $adminPin, 'time_admin_pin' => $timeAdminPin]],
            ['PATCH', $this->baseUrl.'/tss/'.$tssId.'/admin/pin', ['admin_pin' => $adminPin, 'time_admin_pin' => $timeAdminPin]],
            ['POST',  $this->baseUrl.'/tss/'.$tssId.'/admin', ['admin_pin' => $adminPin, 'time_admin_pin' => $timeAdminPin]],
            ['PUT',   $this->baseUrl.'/tss/'.$tssId.'/admin', ['admin_pin' => $adminPin, 'time_admin_pin' => $timeAdminPin]],
        ];

        $last = null;
        foreach ($variants as [$method, $url, $payload]) {
            try {
                return $this->req($method, $url, $token, $payload, 45);
            } catch (\Throwable $e) {
                $last = $e->getMessage();
            }
        }

        throw new \RuntimeException('changeAdminPin failed: '.$last);
    }

    public function adminAuth(string $tssId, string $adminPin, ?string $timeAdminPin = null): array
    {
        $auth = $this->authenticate();
        $token = $auth['access_token'];

        $payloads = [
            array_filter([
                'admin_pin' => $adminPin,
                'time_admin_pin' => $timeAdminPin,
            ], static fn($v) => $v !== null && $v !== ''),
            ['pin' => $adminPin],
            ['admin_pin' => $adminPin],
        ];

        $urls = [
            $this->baseUrl.'/tss/'.$tssId.'/admin/auth',
            $this->baseUrl.'/tss/'.$tssId.'/admin_auth',
            $this->baseUrl.'/tss/'.$tssId.'/admin',
            $this->baseUrl.'/tss/'.$tssId.'/authenticate-admin',
        ];

        $last = null;
        foreach ($urls as $url) {
            foreach ($payloads as $payload) {
                try {
                    $result = $this->req('POST', $url, $token, $payload, 45);
                    if (!isset($result['access_token']) && isset($result['token'])) {
                        $result['access_token'] = $result['token'];
                    }
                    return $result;
                } catch (\Throwable $e) {
                    $last = $e->getMessage();
                }
            }
        }

        throw new \RuntimeException('adminAuth failed: '.$last);
    }

    public function createClient(string $tssId, string $clientId, array $payload, ?string $adminToken = null): array
    {
        $auth = $this->authenticate();
        $token = $adminToken ?: ($auth['access_token'] ?? null);

        $variants = [
            ['PUT',  $this->baseUrl.'/tss/'.$tssId.'/client/'.$clientId, $payload],
            ['PUT',  $this->baseUrl.'/tss/'.$tssId.'/clients/'.$clientId, $payload],
            ['POST', $this->baseUrl.'/tss/'.$tssId.'/client', array_merge(['client_id' => $clientId], $payload)],
            ['POST', $this->baseUrl.'/tss/'.$tssId.'/clients', array_merge(['client_id' => $clientId], $payload)],
        ];

        $last = null;
        foreach ($variants as [$method, $url, $body]) {
            try {
                return $this->req($method, $url, $token, $body, 45);
            } catch (\Throwable $e) {
                $last = $e->getMessage();
            }
        }

        throw new \RuntimeException('createClient failed: '.$last);
    }

    public function upsertTransaction(string $txId, array $payload): array
    {
        $txRevision = (int)($payload['tx_revision'] ?? 1);
        unset($payload['tx_revision']);

        if (empty($payload['receipt_type'])) {
            $payload['receipt_type'] = 'RECEIPT';
        }

        $auth = $this->authenticate();
        $token = $auth['access_token'] ?? null;

        if (!$token) {
            throw new \RuntimeException('Fiskaly auth failed: missing access_token after auth');
        }

        $url = $this->baseUrl.'/tss/'.$this->config->tss_id.'/tx/'.$txId.'?tx_revision='.$txRevision;
        return $this->req('PUT', $url, $token, $payload, 45);
    }
}
