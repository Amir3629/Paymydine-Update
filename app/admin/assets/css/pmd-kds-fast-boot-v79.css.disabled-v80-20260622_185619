/* PMD KDS Fast Boot v79
   Keep backend header, but start the KDS iframe before the normal dashboard widgets finish. */

html.pmd-kds-fast-boot-v79,
body.pmd-kds-fast-boot-v79 {
  overflow-x: hidden !important;
}

/* While KDS dashboard is active, do not show the normal dashboard widgets behind it. */
html.pmd-kds-fast-boot-v79 .pmd-dashboard-modern > :not(.pmd-kds-dashboard-host-v76),
body.pmd-kds-fast-boot-v79 .pmd-dashboard-modern > :not(.pmd-kds-dashboard-host-v76),
html.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .dashboard-toolbar,
html.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .dashboard-widgets,
html.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .widget-container,
html.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .progress-indicator,
body.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .dashboard-toolbar,
body.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .dashboard-widgets,
body.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .widget-container,
body.pmd-kds-fast-boot-v79 [data-control="dashboard-container"] > .progress-indicator {
  display: none !important;
}

/* The temporary preloaded iframe is off-screen only until we can mount it under the normal header. */
.pmd-kds-dashboard-host-v76.pmd-kds-fast-preloading-v79 {
  position: absolute !important;
  left: -10000px !important;
  top: 0 !important;
  width: 1px !important;
  height: 1px !important;
  min-height: 1px !important;
  margin: 0 !important;
  padding: 0 !important;
  opacity: 0 !important;
  overflow: hidden !important;
  pointer-events: none !important;
  border: 0 !important;
  box-shadow: none !important;
}

html.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-host-v76,
body.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-host-v76 {
  position: relative !important;
  display: block !important;
  width: calc(100% - 36px) !important;
  max-width: none !important;
  min-height: calc(100vh - 145px) !important;
  margin: 18px !important;
  border: 0 !important;
  border-radius: 18px !important;
  background: #ffffff !important;
  box-shadow: 0 18px 50px rgba(15, 23, 42, 0.10) !important;
  overflow: hidden !important;
}

html.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-iframe-v76,
body.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-iframe-v76 {
  display: block !important;
  width: 100% !important;
  height: calc(100vh - 145px) !important;
  min-height: 720px !important;
  border: 0 !important;
  background: #ffffff !important;
}

/* Very light visible skeleton for the first instant before the iframe paints. */
html.pmd-kds-fast-visible-v79:not(.pmd-kds-fast-loaded-v79) .pmd-kds-dashboard-host-v76::before,
body.pmd-kds-fast-visible-v79:not(.pmd-kds-fast-loaded-v79) .pmd-kds-dashboard-host-v76::before {
  content: 'Loading Kitchen Display…';
  position: absolute !important;
  inset: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  z-index: 2 !important;
  background: linear-gradient(135deg, #fffaf1, #ffffff) !important;
  color: #064236 !important;
  font-weight: 800 !important;
  letter-spacing: .02em !important;
}

html.pmd-kds-fast-loaded-v79 .pmd-kds-dashboard-host-v76::before,
body.pmd-kds-fast-loaded-v79 .pmd-kds-dashboard-host-v76::before {
  display: none !important;
}

@media (max-width: 767px) {
  html.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-host-v76,
  body.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-host-v76 {
    width: calc(100% - 20px) !important;
    margin: 10px !important;
    border-radius: 12px !important;
    min-height: calc(100vh - 105px) !important;
  }

  html.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-iframe-v76,
  body.pmd-kds-fast-visible-v79 .pmd-kds-dashboard-iframe-v76 {
    height: calc(100vh - 105px) !important;
    min-height: 620px !important;
  }
}
