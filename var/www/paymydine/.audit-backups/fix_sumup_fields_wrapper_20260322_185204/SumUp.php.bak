<?php

namespace Igniter\PayRegister\Payments;

use Admin\Classes\BasePaymentGateway;

class SumUp extends BasePaymentGateway
{
    public function defineGatewayFormFields()
    {
        $fields = include __DIR__.'/sumup/fields.php';

        if (is_array($fields) && array_key_exists('fields', $fields)) {
            return $fields;
        }

        return ['fields' => $fields];
    }

    public function getConfigFields()
    {
        $config = $this->defineGatewayFormFields();

        return is_array($config) ? ($config['fields'] ?? []) : [];
    }

    public function getConfigRules()
    {
        return [
            'transaction_mode' => ['required', 'in:test,live'],
            'test_api_key' => ['nullable', 'string', 'max:255'],
            'live_api_key' => ['nullable', 'string', 'max:255'],
            'test_public_key' => ['nullable', 'string', 'max:255'],
            'live_public_key' => ['nullable', 'string', 'max:255'],
            'merchant_code' => ['nullable', 'string', 'max:255'],
            'base_url' => ['nullable', 'string', 'max:255'],
            'return_url' => ['nullable', 'string', 'max:255'],
            'webhook_url' => ['nullable', 'string', 'max:255'],
            'order_status' => ['nullable'],
            'order_total' => ['nullable'],
            'order_fee' => ['nullable'],
            'order_fee_type' => ['nullable'],
        ];
    }

    public function getConfigValidationMessages()
    {
        return [];
    }

    public function getConfigValidationAttributes()
    {
        return [];
    }

    public function isApplicable($total, $host)
    {
        return $host->order_total <= $total;
    }
}
