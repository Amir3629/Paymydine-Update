<style>
#pmd-pos-tax-note-safe {
    margin-top: 18px !important;
    margin-bottom: 14px !important;
    padding: 12px 14px;
    border: 1px solid #d9e2ef;
    border-radius: 12px;
    background: #f8fbff;
    color: #364a63;
    font-size: 14px;
    line-height: 1.6;
}
#pmd-pos-tax-note-safe .pmd-pos-tax-title {
    font-weight: 700;
    margin-bottom: 6px;
}
</style>

<script>
(function () {
    function getOrderIdFromUrl() {
        try {
            var m = window.location.pathname.match(/\/admin\/orders\/edit\/(\d+)/);
            return m ? m[1] : null;
        } catch (e) {
            return null;
        }
    }

    function formatMoney(v) {
        var n = Number(v);
        if (isNaN(n)) return null;
        return '€' + n.toFixed(2);
    }

    function makeNote(meta) {
        var box = document.createElement('div');
        box.id = 'pmd-pos-tax-note-safe';

        var title = document.createElement('div');
        title.className = 'pmd-pos-tax-title';
        title.textContent = 'POS import tax info';

        var text = document.createElement('div');
        var parts = [];
        if (meta && meta.source) parts.push('Source: ' + meta.source);
        if (meta && meta.invoice_number) parts.push('Invoice: ' + meta.invoice_number);
        if (meta && meta.gross !== null && meta.gross !== undefined) parts.push('Gross: ' + formatMoney(meta.gross));
        if (meta && meta.net !== null && meta.net !== undefined) parts.push('Net: ' + formatMoney(meta.net));
        if (meta && meta.vat !== null && meta.vat !== undefined) parts.push('VAT: ' + formatMoney(meta.vat));
        text.textContent = parts.join(' | ') || 'POS imported order';

        var hint = document.createElement('div');
        hint.textContent = 'This tax display comes from POS import data, not PayMyDine tax settings.';
        hint.style.marginTop = '6px';
        hint.style.opacity = '0.85';

        box.appendChild(title);
        box.appendChild(text);
        box.appendChild(hint);
        return box;
    }

    function mountNote(meta) {
        var old = document.getElementById('pmd-pos-tax-note-safe');
        if (old) old.remove();

        var note = makeNote(meta);
        var header = document.querySelector('.order-info-header');
        if (header && header.parentNode) {
            if (header.nextSibling) {
                header.parentNode.insertBefore(note, header.nextSibling);
            } else {
                header.parentNode.appendChild(note);
            }
            return;
        }

        var firstCardBody = document.querySelector('.card-body');
        if (firstCardBody) {
            firstCardBody.insertBefore(note, firstCardBody.firstChild);
        }
    }

    function applyHeaderFix(meta) {
        var tableValue = document.querySelector('.order-info-item.table-number .order-info-value');
        if (!tableValue) return;

        var name = null;
        if (meta) {
            if (meta.mapped_local_table_name) name = meta.mapped_local_table_name;
            else if (meta.table_name) name = meta.table_name;
        }

        if (!name) {
            var bodyText = document.body.innerText || '';
            var m1 = bodyText.match(/mapped_local_table_name=([^|\n]+)/i);
            if (m1 && m1[1]) name = m1[1].trim();
            if (!name) {
                var m2 = bodyText.match(/table_name=([^|\n]+)/i);
                if (m2 && m2[1]) name = m2[1].trim();
            }
        }

        if (name && name !== 'Table' && name !== 'Table ') {
            tableValue.textContent = name;
        }
    }

    function triggerBillPatch(meta) {
        window.__PMD_POS_META = meta || null;

        var tries = 0;
        function ping() {
            tries++;
            if (typeof window.PMD_POS_META_APPLY === 'function') {
                window.PMD_POS_META_APPLY(meta || null);
            }
            if (tries < 8) setTimeout(ping, 400);
        }
        ping();
    }

    function run() {
        var orderId = getOrderIdFromUrl();
        if (!orderId) return;

        fetch('/order_pos_tax_lookup_ajax.php?order_id=' + encodeURIComponent(orderId), {
            credentials: 'same-origin',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(function (r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function (data) {
            if (!data || !data.success || !data.meta || !data.meta.is_pos_import) return;
            mountNote(data.meta);
            applyHeaderFix(data.meta);
            triggerBillPatch(data.meta);
        })
        .catch(function (err) {
            console.log('PMD order edit POS patch skipped:', err.message);
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        setTimeout(run, 250);
        setTimeout(run, 900);
        setTimeout(run, 1800);
    });
})();
</script>
