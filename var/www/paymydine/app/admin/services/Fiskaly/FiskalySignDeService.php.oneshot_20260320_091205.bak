<?php

namespace Admin\Services\Fiskaly;

use Illuminate\Support\Facades\DB;

class FiskalySignDeService
{
    public function finalizeOrder($order)
    {
        $tx = DB::table('fiskaly_transactions')
            ->where('order_id', $orderId)
            ->first();

        if (!$tx) {
            throw new \RuntimeException("Transaction not found");
        }

        $api = app(\Admin\Services\Fiskaly\FiskalyApiClient::class);

        // ✅ STEP 1 — START
        $start = $api->upsertTransaction($tx->tx_id, [
            'tx_revision' => 1,
            'state' => 'ACTIVE',
            'client_id' => $tx->client_id,
            'receipt_type' => 'RECEIPT'
        ]);

        // ✅ BUILD RECEIPT
        $builder = app(\Admin\Services\Fiskaly\FiskalyReceiptDataBuilder::class);
        $receipt = $builder->buildForOrder($orderId);

        // ✅ STEP 2 — UPDATE WITH SCHEMA
        $update = $api->upsertTransaction($tx->tx_id, array_merge([
            'tx_revision' => 2,
            'state' => 'ACTIVE',
            'client_id' => $tx->client_id,
        ], $receipt));

        // ✅ STEP 3 — FINISH
        $finish = $api->upsertTransaction($tx->tx_id, [
            'tx_revision' => 3,
            'state' => 'FINISHED',
            'client_id' => $tx->client_id,
            'receipt_type' => 'RECEIPT'
        ]);

        DB::table('fiskaly_transactions')
            ->where('order_id', $orderId)
            ->update([
                'status' => 'done',
                'tx_state' => $finish['state'] ?? null,
                'tx_number' => $finish['number'] ?? null,
                'signature_counter' => $finish['signature']['counter'] ?? null,
                'signature_value' => $finish['signature']['value'] ?? null,
                'qr_code_data' => $finish['qr_code_data'] ?? null,
                'updated_at' => now()
            ]);

        return [
            'start' => $start,
            'update' => $update,
            'finish' => $finish
        ];
    }
}
