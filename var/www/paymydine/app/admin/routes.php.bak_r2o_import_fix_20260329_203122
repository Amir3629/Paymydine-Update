                \Log::warning('Failed to create new order notification', [
                    'order_id' => $orderId,
                    'error' => $e->getMessage(),
                ]);
            }

            \Log::info('PMD_ACTIVE_ORDER_ROUTE_SUCCESS', [
                'order_id' => $orderId,
                'base_items_subtotal' => $baseItemsSubtotal,
                'options_subtotal' => $optionsSubtotal,
