            $isZeroDecimal = in_array($currency, $zeroDecimalCurrencies);
            $amountMinor = $isZeroDecimal ? (int) round($amountMajor) : (int) round($amountMajor * 100);
            $preferred = $body['preferredMethod'] ?? null;

