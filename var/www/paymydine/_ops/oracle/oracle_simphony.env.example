# Oracle Simphony bootstrap env
# Fill this file, then copy to oracle_simphony.env

# Base host only, no trailing slash
# Example:
# ORACLE_BASE_URL="https://your-oracle-host.example.com"
ORACLE_BASE_URL=""

# OAuth / OIDC client info
ORACLE_CLIENT_ID=""
ORACLE_ID_TOKEN=""
ORACLE_REFRESH_TOKEN=""

# Optional but recommended
ORACLE_REDIRECT_URI="apiaccount://callback"

# Discovery context
ORACLE_ORG_SHORT_NAME=""
ORACLE_LOC_REF=""
ORACLE_RVC_REF=""

# Optional
ORACLE_ACCEPT_LANGUAGE="en-US"
ORACLE_SIMPHONY_FEATURES="detect-duplicate-request"
