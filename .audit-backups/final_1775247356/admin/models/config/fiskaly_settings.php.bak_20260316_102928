                'type' => 'select',
                'default' => 'test',
                'options' => [
                    'test' => 'Test',
                    'live' => 'Live',
                ],
                'comment' => 'Use test while onboarding. Switch to live only with real production credentials.',
                'span' => 'right',
            ],

            'fiskaly_api_key' => [
                'label' => 'API Key',
                'type' => 'text',
                'span' => 'left',
            ],

            'fiskaly_api_secret' => [
                'label' => 'API Secret',
                'type' => 'text',
                'span' => 'right',
