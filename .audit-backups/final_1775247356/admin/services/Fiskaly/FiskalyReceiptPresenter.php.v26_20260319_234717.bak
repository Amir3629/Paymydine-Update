<?php

namespace Admin\Services\Fiskaly;

use Admin\Models\Fiskaly_configs_model;
use Illuminate\Support\Facades\DB;

class FiskalyReceiptPresenter
{
    public function presentForOrder($order): array
    {
        $orderArray = $this->toArray($order);
        $orderId = $orderArray['order_id'] ?? $orderArray['id'] ?? null;
        $locationId = $orderArray['location_id'] ?? 1;

        $config = $this->readConfig($locationId);
        $configMeta = is_array($config['meta'] ?? null) ? $config['meta'] : [];
        $tx = $this->readTransactionData($orderId);

        $flat = [];
        foreach ([$orderArray, $config, $configMeta, $tx] as $source) {
            $flat = array_merge($flat, $this->flatten($source));
        }

        $qrData = $this->pick($flat, [
            'qr_code_data',
            'receipt_qr_code_data',
            'fiskaly_qr_code_data',
            'tx.qr_code_data',
            'transaction.qr_code_data',
            'response.qr_code_data',
            'finish_response.qr_code_data',
            'create_transaction_response.qr_code_data',
            'update_transaction_response.qr_code_data',
        ]);

        $tssId = $this->pick($flat, [
            'tss_id',
            'fiskaly_tss_id',
            'get_tss_response._id',
        ]) ?: ($config['tss_id'] ?? null);

        $tssSerial = $this->pick($flat, [
            'tss_serial_number',
            'fiskaly_tss_serial_number',
            'get_tss_response.serial_number',
        ]);

        $clientId = $this->pick($flat, [
            'client_id',
            'fiskaly_client_id',
            'create_client_response._id',
        ]) ?: ($config['client_id'] ?? null);

        $clientSerial = $this->pick($flat, [
            'client_serial_number',
            'fiskaly_client_serial_number',
            'meta.client_serial_number',
            'create_client_response.serial_number',
        ]);

        $txId = $this->pick($flat, [
            'tx_id',
            'transaction_id',
            'fiskaly_tx_id',
            'fiskaly_transaction_id',
        ]);

        $txNumber = $this->pick($flat, [
            'transaction_number',
            'tx_number',
            'fiskaly_transaction_number',
        ]);

        $signatureCounter = $this->pick($flat, [
            'signature_counter',
            'fiskaly_signature_counter',
            'get_tss_response.signature_counter',
        ]);

        $timeStart = $this->normalizeTime($this->pick($flat, [
            'time_start',
            'fiskaly_time_start',
            'transaction.time_start',
        ]));

        $timeEnd = $this->normalizeTime($this->pick($flat, [
            'time_end',
            'fiskaly_time_end',
            'transaction.time_end',
        ]));

        $signatureValue = $this->crop($this->pick($flat, [
            'signature.value',
            'signature_value',
            'fiskaly_signature_value',
        ]), 120);

        $signatureAlgorithm = $this->pick($flat, [
            'signature.algorithm',
            'signature_algorithm',
            'fiskaly_signature_algorithm',
            'get_tss_response.signature_algorithm',
        ]);

        $publicKey = $this->crop($this->pick($flat, [
            'signature.public_key',
            'public_key',
            'fiskaly_public_key',
            'get_tss_response.public_key',
        ]), 120);

        $timestampFormat = $this->pick($flat, [
            'log.timestamp_format',
            'timestamp_format',
            'fiskaly_timestamp_format',
            'get_tss_response.signature_timestamp_format',
        ]);

        $isEnabled = (bool)($config['is_enabled'] ?? false);
        $hasData = (bool)($qrData || $tssId || $tssSerial || $clientId || $clientSerial || $txId || $txNumber || $signatureValue);

        $lines = [
            ['label' => 'TSE-ID', 'value' => $tssId],
            ['label' => 'TSE-Seriennummer', 'value' => $tssSerial],
            ['label' => 'Client-ID', 'value' => $clientId],
            ['label' => 'Kassen-Seriennummer', 'value' => $clientSerial],
            ['label' => 'Transaktions-ID', 'value' => $txId],
            ['label' => 'Transaktionsnummer', 'value' => $txNumber],
            ['label' => 'Signaturzähler', 'value' => $signatureCounter],
            ['label' => 'Startzeit', 'value' => $timeStart],
            ['label' => 'Endzeit', 'value' => $timeEnd],
            ['label' => 'Algorithmus', 'value' => $signatureAlgorithm],
            ['label' => 'Zeitformat', 'value' => $timestampFormat],
            ['label' => 'Signatur', 'value' => $signatureValue],
            ['label' => 'Public Key', 'value' => $publicKey],
        ];

        return [
            'enabled' => $isEnabled || $hasData,
            'has_any' => $hasData,
            'has_qr' => !empty($qrData),
            'qr_data' => $qrData,
            'qr_src' => $qrData ? ('https://api.qrserver.com/v1/create-qr-code/?size=170x170&data='.rawurlencode($qrData)) : null,
            'intro' => 'Dieser Beleg enthält Fiskaly / TSE-Informationen gemäß KassenSichV.',
            'lines' => array_values(array_filter($lines, function ($line) {
                return !empty($line['value']);
            })),
        ];
    }

    protected function readConfig($locationId): array
    {
        try {
            $cfg = Fiskaly_configs_model::where('location_id', $locationId ?: 1)->first();
            if (!$cfg && (int)$locationId !== 1) {
                $cfg = Fiskaly_configs_model::where('location_id', 1)->first();
            }

            return $cfg ? $this->toArray($cfg) : [];
        } catch (\Throwable $e) {
            return [];
        }
    }

    protected function readTransactionData($orderId): array
    {
        if (!$orderId) {
            return [];
        }

        try {
            if (!DB::getSchemaBuilder()->hasTable('fiskaly_transactions')) {
                return [];
            }

            $row = DB::table('fiskaly_transactions')
                ->where('order_id', $orderId)
                ->orderByDesc('fiskaly_transaction_id')
                ->first();

            if (!$row) {
                return [];
            }

            $arr = (array)$row;

            foreach ($arr as $k => $v) {
                if (is_string($v) && $this->looksLikeJson($v)) {
                    $decoded = json_decode($v, true);
                    if (json_last_error() === JSON_ERROR_NONE) {
                        $arr[$k] = $decoded;
                    }
                }
            }

            return $arr;
        } catch (\Throwable $e) {
            return [];
        }
    }

    protected function toArray($value): array
    {
        if (is_array($value)) {
            return $value;
        }

        if (is_object($value)) {
            if (method_exists($value, 'toArray')) {
                try {
                    return $value->toArray();
                } catch (\Throwable $e) {
                }
            }

            return get_object_vars($value);
        }

        return [];
    }

    protected function flatten($data, string $prefix = ''): array
    {
        $out = [];

        if (!is_array($data)) {
            return $out;
        }

        foreach ($data as $key => $value) {
            $full = $prefix === '' ? (string)$key : $prefix.'.'.$key;

            if (is_array($value)) {
                $out += $this->flatten($value, $full);
            } elseif (is_scalar($value) || $value === null) {
                $out[$full] = $value;
            }
        }

        return $out;
    }

    protected function pick(array $flat, array $candidates): ?string
    {
        foreach ($candidates as $candidate) {
            if (array_key_exists($candidate, $flat) && $flat[$candidate] !== null && $flat[$candidate] !== '') {
                return (string)$flat[$candidate];
            }
        }

        foreach ($flat as $key => $value) {
            if ($value === null || $value === '') {
                continue;
            }

            foreach ($candidates as $candidate) {
                if (str_ends_with($key, '.'.$candidate) || $key === $candidate) {
                    return (string)$value;
                }
            }
        }

        return null;
    }

    protected function normalizeTime($value): ?string
    {
        if ($value === null || $value === '') {
            return null;
        }

        if (is_numeric($value)) {
            $ts = (int)$value;
            if ($ts > 0) {
                return gmdate('Y-m-d H:i:s', $ts).' UTC';
            }
        }

        return (string)$value;
    }

    protected function crop($value, int $max = 120): ?string
    {
        if ($value === null || $value === '') {
            return null;
        }

        $value = (string)$value;

        if (mb_strlen($value) <= $max) {
            return $value;
        }

        return mb_substr($value, 0, $max).'...';
    }

    protected function looksLikeJson(string $value): bool
    {
        $trim = trim($value);
        if ($trim === '') {
            return false;
        }

        return (
            (str_starts_with($trim, '{') && str_ends_with($trim, '}')) ||
            (str_starts_with($trim, '[') && str_ends_with($trim, ']'))
        );
    }
}
