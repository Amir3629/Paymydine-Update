<?php

namespace Admin\Services\Fiskaly;

use Illuminate\Support\Facades\DB;

class FiskalyReceiptDataBuilder
{
    public function buildForOrder(int $orderId): array
    {
        $order = DB::table('orders')->where('order_id', $orderId)->first();
        $items = DB::table('order_menus')->where('order_id', $orderId)->get();

        $lines = [];

        foreach ($items as $item) {
            $qty = (int)($item->quantity ?? 1);
            $unit = (float)($item->price ?? 0);
            $total = $qty * $unit;

            $lines[] = [
                'text' => (string)$item->name,
                'quantity' => (string)$qty,
                'price_per_unit' => number_format($unit, 2, '.', ''),
                'amount' => number_format($total, 2, '.', ''),
                'vat_rate' => "0"
            ];
        }

        $totalAmount = number_format((float)$order->order_total, 2, '.', '');

        return [
            'receipt_type' => 'RECEIPT',

            'schema' => [
                'standard_v1' => [
                    'receipt' => [
                        'type' => 'RECEIPT',
                        'currency_code' => 'EUR',
                        'buyer' => new \stdClass(),

                        'line_items' => $lines,

                        'payments' => [
                            [
                                'type' => 'CASH',
                                'amount_per_payment_type' => $totalAmount
                            ]
                        ],

                        'amounts_per_vat_rate' => [
                            [
                                'vat_rate' => "0",
                                'amount' => $totalAmount
                            ]
                        ]
                    ]
                ]
            ]
        ];
    }
}
