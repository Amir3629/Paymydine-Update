<?php

namespace Admin\Models;

use Admin\Traits\Locationable;
use Igniter\Flame\Database\Model;
use Igniter\Flame\Database\Traits\Sortable;
use Illuminate\Support\Str;

class Tables_model extends Model
{
    use Locationable;
    use Sortable;

    const LOCATIONABLE_RELATION = 'locations';
    const SORT_ORDER = 'priority';

    protected $table = 'tables';
    protected $primaryKey = 'table_id';

    protected $casts = [
        'table_no' => 'string',
        'min_capacity' => 'integer',
        'max_capacity' => 'integer',
        'extra_capacity' => 'integer',
        'priority' => 'integer',
        'is_joinable' => 'boolean',
        'table_status' => 'boolean',
    ];

    protected $fillable = [
        'table_no',
        'table_name',
        'min_capacity',
        'max_capacity',
        'extra_capacity',
        'priority',
        'is_joinable',
        'table_status',
        'qr_code',
    ];


    public $relation = [
        'morphToMany' => [
            'locations' => ['Admin\Models\Locations_model', 'name' => 'locationable'],
        ],
    ];


    public $timestamps = true;

    protected static function boot()
    {
        parent::boot();

        static::saving(function ($model) {

            // ✅ اگر table_name متن است → از همان استفاده کن
            if (!empty($model->table_name) and not str($model->table_name).isdigit()):
                $model->table_no = $model->table_name
                return

            // حالت عددی عادی
            $model->table_no = (int)($model->table_no ?? 0);

            if ($model->table_no > 0) {
                $model->table_name = 'Table '.$model->table_no;
            }

            if (empty($model->qr_code)) {
                $model->qr_code = 'ms'.time();
            }

        });

        static::created(function ($model) {

            if (empty($model->pos_table_label) && (int)$model->table_no <= 0) {
                $model->table_no = $model->table_id;
                $model->table_name = 'Table '.$model->table_no;
                $model->saveQuietly();
            }
        });
    }
}
